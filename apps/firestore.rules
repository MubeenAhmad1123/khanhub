rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    //  SHARED HELPERS  (job platform — do not modify)
    // ═══════════════════════════════════════════════════════════

    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('role', '') == 'admin';
    }

    // ═══════════════════════════════════════════════════════════
    //  JOB PLATFORM COLLECTIONS  (unchanged — do not modify)
    // ═══════════════════════════════════════════════════════════

    // ── Users ─────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        || isAdmin()
        || (isAuth() && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly([
              'followerCount', 'followingCount',
              'likedVideos', 'savedVideos',
              'interestedVideos', 'notInterestedVideos',
              'totalLikes', 'watchedVideos'
            ]));
      allow delete: if isAdmin();
    }

    // ── Videos ───────────────────────────────────────
    match /videos/{videoId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid)
        || (isAuth() && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['views', 'likes', 'likedBy']));
      allow delete: if isAdmin();
    }

    // ── Follows ───────────────────────────────────────
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.followerId == request.auth.uid;
    }

    // ── Notifications ─────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Payments ──────────────────────────────────────
    match /payments/{payId} {
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Payment Requests ──────────────────────────────
    match /paymentRequests/{reqId} {
      allow read: if isAuth()
        && (resource.data.requestedBy == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Video Payments ────────────────────────────────
    match /videoPayments/{reqId} {
      allow read: if isAuth()
        && (resource.data.requestedBy == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Jobs ──────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth()
        && (resource.data.employerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Applications ──────────────────────────────────
    match /applications/{appId} {
      allow read: if isAuth()
        && (resource.data.applicantId == request.auth.uid
            || resource.data.employerId == request.auth.uid
            || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Connections ───────────────────────────────────
    match /connections/{conId} {
      allow read: if isAuth()
        && (resource.data.seekerId == request.auth.uid
            || resource.data.employerId == request.auth.uid
            || isAdmin());
      allow create: if isAuth();
      allow update: if isAuth()
        && (resource.data.seekerId == request.auth.uid
            || resource.data.employerId == request.auth.uid
            || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Admin Settings ────────────────────────────────
    match /adminSettings/{doc} {
      allow read, write: if isAdmin();
    }

    // ── Likes (Fallback rule) ─────────────────────────
    match /likes/{likeId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ── Video Feedback ────────────────────────────────
    match /video_feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Reports ───────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth()
        && request.resource.data.reportedBy == request.auth.uid;
    }

    // ── Interests ─────────────────────────────────────
    match /interests/{interestId} {
      allow read: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════
    //  REHAB PORTAL HELPERS
    //  Separate from job platform — uses rehab_users collection
    //  The isAdmin() above checks /users/ — these check /rehab_users/
    // ═══════════════════════════════════════════════════════════

    function isRehabAuth() {
      return request.auth != null
        && exists(/databases/$(database)/documents/rehab_users/$(request.auth.uid));
    }
    function rehabRole() {
      return get(/databases/$(database)/documents/rehab_users/$(request.auth.uid)).data.role;
    }
    function isRehabRole(role) {
      return isRehabAuth() && rehabRole() == role;
    }
    function isRehabAdminOrAbove() {
      return isRehabAuth()
        && (rehabRole() == 'admin' || rehabRole() == 'superadmin');
    }
    function isRehabSuperAdmin() {
      return isRehabRole('superadmin');
    }
    function rehabPatientId() {
      return get(/databases/$(database)/documents/rehab_users/$(request.auth.uid)).data.patientId;
    }
    function rehabStaffId() {
      return get(/databases/$(database)/documents/rehab_users/$(request.auth.uid)).data.staffId;
    }

    // ═══════════════════════════════════════════════════════════
    //  REHAB PORTAL COLLECTIONS
    // ═══════════════════════════════════════════════════════════

    // ── Setup meta (one-time init flag) ───────────────
    // Public read so setup page can check if system is initialized.
    // Write is false from client — only server action (Firebase Admin) writes this.
    match /rehab_meta/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ── Rehab user profiles ────────────────────────────
    // Users can read their own profile.
    // Admin/superadmin can read all.
    // Write is false from client — only server action (Firebase Admin) creates/updates.
    match /rehab_users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isRehabAdminOrAbove());
      allow create: if false;
      allow delete: if false;
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['photoUrl', 'displayName', 'phone']);
    }

    // ── Patients ───────────────────────────────────────
    // Family can only read their linked patient.
    // Admin/superadmin can read and write all.
    // Delete only by superadmin.
    match /rehab_patients/{patientId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('family') && rehabPatientId() == patientId);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Fee records ────────────────────────────────────
    // Family can read only their patient's fee record.
    // Cashier and superadmin can write.
    // Admin can read all (for reports).
    match /rehab_fees/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('cashier'))
        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId);
      allow write: if isRehabRole('cashier') || isRehabSuperAdmin();
    }

    // ── Canteen records ────────────────────────────────
    match /rehab_canteen/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('cashier'))
        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId);
      allow write: if isRehabRole('cashier') || isRehabSuperAdmin();
    }

    // ── Transactions ───────────────────────────────────
    // Cashier creates. Superadmin approves/rejects (update).
    // Admin and superadmin can read all. Cashier reads own entries.
    // Nobody deletes transactions — full audit trail.


    // ── Staff profiles ─────────────────────────────────
    // Staff can read their own profile only.
    // Admin/superadmin can read and write all.
    match /rehab_staff/{staffId} {
      allow read: if isRehabAdminOrAbove() || isRehabRole('staff');
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Attendance ─────────────────────────────────────
    // Staff can create their own attendance (self check-in).
    // Admin can update (override). Nobody deletes.
    match /rehab_attendance/{docId} {
      allow read: if isRehabAdminOrAbove()
        || isRehabRole('cashier')
        || isRehabRole('staff');
      allow create: if isRehabRole('staff') || isRehabAdminOrAbove();
      allow update: if isRehabRole('staff') || isRehabAdminOrAbove();
      allow delete: if false;
    }

    // ── Patient videos ─────────────────────────────────
    // Family can read only their patient's videos.
    // Admin/superadmin can read and write all.
    match /rehab_videos/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Audit log ──────────────────────────────────────
    // Only superadmin can read. 
    // Server actions write via Admin SDK (bypasses rules).
    // Client writes allowed for fire-and-forget audit entries
    // from authenticated rehab users only.
    match /rehab_audit/{docId} {
      allow read: if isRehabSuperAdmin();
      allow create: if isRehabAuth();
      allow update, delete: if false;
    }

    // ── Staff contributions ────────────────────────────
    // Staff write their own contributions.
    // Admin/superadmin can read all.
    // Nobody deletes or edits.
    match /rehab_contributions/{docId} {
      allow read: if isRehabAdminOrAbove() || isRehabRole('staff');
      allow create: if isRehabRole('staff') || isRehabAdminOrAbove();
      allow update, delete: if false;
    }

    // ── Staff fines ────────────────────────────────────
    // Admin/superadmin read and write. Staff reads own fines.
    match /rehab_fines/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('staff') 
            && resource.data.staffId == request.auth.uid);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Staff leaves ───────────────────────────────────
    // Admin/superadmin read and write. Staff reads own leaves.
    match /rehab_leaves/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('staff') 
            && resource.data.staffId == request.auth.uid);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    //  HQ PORTAL HELPERS
    // ═══════════════════════════════════════════════════════════

    function isHqAuth() {
      return request.auth != null && exists(/databases/$(database)/documents/hq_users/$(request.auth.uid));
    }
    function hqUserDoc() {
      return get(/databases/$(database)/documents/hq_users/$(request.auth.uid)).data;
    }
    function isHqRole(role) {
      return isHqAuth() && hqUserDoc().role == role;
    }
    function isHqAdmin() {
      return isHqAuth() && (hqUserDoc().role == 'manager' || hqUserDoc().role == 'superadmin');
    }
    function isHqSuperadmin() { return isHqRole('superadmin'); }
    function isHqManager() { return isHqRole('manager'); }
    function isHqCashier() { return isHqRole('cashier'); }

    // ═══════════════════════════════════════════════════════════
    //  HQ PORTAL COLLECTIONS
    // ═══════════════════════════════════════════════════════════

    match /hq_users/{uid} {
      allow read: if isHqAuth() && (request.auth.uid == uid || isHqAdmin());
      allow write: if isHqSuperadmin();
      
      // Allow users to manage their own FCM tokens
      match /fcmTokens/{tokenId} {
        allow read, write: if isHqAuth() && request.auth.uid == uid;
      }
    }

    match /hq_staff/{staffId} {
      allow read: if isHqAuth();
      allow write: if isHqAdmin();
    }

    match /hq_attendance/{docId} {
      allow read: if isHqAuth();
      allow write: if isHqAdmin();
    }

    match /hq_duty_logs/{docId} {
      allow read: if isHqAuth();
      allow write: if isHqAdmin();
    }

    match /hq_dress_code/{docId} {
      allow read: if isHqAuth();
      allow write: if isHqAdmin();
    }

    match /hq_duties/{docId} {
      allow read: if isHqAuth();
      allow write: if isHqAdmin();
    }

    match /hq_transactions/{docId} {
      allow read: if isHqAuth();
      allow write: if isHqAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    //  DEPARTMENTAL TRANSACTIONS (Unified Access)
    //  Includes: rehab, spims, hospital, sukoon, welfare, job_center
    // ═══════════════════════════════════════════════════════════

    match /{dept}_transactions/{docId} {
      allow read: if isHqAuth() || isRehabAuth() || isSpimsAuth() || isJobCenterAuth();
      
      allow create: if isHqManager() || isHqCashier() || isHqSuperadmin() 
                    || isRehabAdminOrAbove() || isSpimsAdminOrAbove();
      
      allow update: if isHqSuperadmin() 
                    || (isHqCashier() && resource.data.status == 'pending_cashier')
                    || (isRehabAdminOrAbove() && resource.data.status == 'pending_cashier');
      
      allow delete: if isHqSuperadmin();
    }

    match /hq_audit/{docId} {
      allow read: if isHqAdmin();
      allow create: if isHqAuth();
    }

    match /hq_settings/{docId} {
      allow read: if isHqAuth();
      allow write: if isHqSuperadmin();
    }

    function isJobCenterAuth() {
      return request.auth != null;
    }
    
    function jobCenterUserDoc() {
      return get(/databases/$(database)/documents/jobcenter_users/$(request.auth.uid)).data;
    }
    
    function isJobCenterAdmin() {
      return isJobCenterAuth() && (jobCenterUserDoc().role == 'admin' || jobCenterUserDoc().role == 'superadmin');
    }
    
    function isJobCenterStaff() {
      return isJobCenterAuth() && (jobCenterUserDoc().role == 'staff' || isJobCenterAdmin());
    }

    // ═══════════════════════════════════════════════════════════
    //  JOB CENTER PORTAL COLLECTIONS
    // ═══════════════════════════════════════════════════════════

    match /jobcenter_users/{uid} {
      allow read: if isJobCenterAuth() && (request.auth.uid == uid || isJobCenterAdmin());
      allow write: if isJobCenterAdmin();
    }

    match /jobcenter_seekers/{seekerId} {
      allow read: if isJobCenterAuth();
      allow create, update: if isJobCenterAdmin();
      allow delete: if isJobCenterAdmin();
    }

    match /jobcenter_employers/{employerId} {
      allow read: if isJobCenterAuth();
      allow create, update: if isJobCenterAdmin();
      allow delete: if isJobCenterAdmin();
    }

    match /jobcenter_jobs/{jobId} {
      allow read: if true; // Public or seeker access
      allow create, update: if isJobCenterAdmin() || (isJobCenterAuth() && jobCenterUserDoc().role == 'employer');
      allow delete: if isJobCenterAdmin();
    }

    match /jobcenter_transactions/{docId} {
      allow read: if isHqAuth() || isJobCenterAuth();
      allow write: if isHqAdmin() || isJobCenterAuth();
    }

    match /jobcenter_attendance/{docId} {
      allow read: if isJobCenterAuth();
      allow write: if isJobCenterStaff();
    }

    match /jobcenter_daily_activities/{docId} {
      allow read: if isJobCenterAuth();
      allow write: if isJobCenterStaff();
    }

    match /jobcenter_contributions/{docId} {
      allow read: if isJobCenterAuth();
      allow create: if isJobCenterStaff();
      allow update, delete: if isJobCenterAdmin();
    }

    match /jobcenter_audit/{docId} {
      allow read: if isJobCenterAdmin();
      allow create: if isJobCenterAuth();
    }

    match /jobcenter_videos/{docId} {
      allow read: if true;
      allow create: if isJobCenterAuth();
      allow update, delete: if isJobCenterAdmin();
    }

    match /jobcenter_meetings/{docId} {
      allow read: if isJobCenterAuth();
      allow create, update: if isJobCenterStaff();
      allow delete: if isJobCenterAdmin();
    }

    match /jobcenter_staff/{docId} {
      allow read: if isJobCenterAuth();
      allow write: if isJobCenterAdmin();
    }

  }
}
