rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('role', '') == 'admin';
    }
    function isCashier() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('role', '') == 'cashier';
    }

    // ── Users ─────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        || isAdmin()
        || (isAuth() && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly([
              'followerCount', 'followingCount',
              'likedVideos', 'savedVideos',
              'interestedVideos', 'notInterestedVideos',
              'totalLikes', 'watchedVideos'
            ]));
      allow delete: if isAdmin();
    }

    // ── Videos ───────────────────────────────────────
    match /videos/{videoId} {
      // Everyone reads — guests included:
      allow read: if true;

      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid)
        || (isAuth() && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['views', 'likes', 'likedBy']));

      allow delete: if isAdmin();
    }

    // ── Follows ───────────────────────────────────────
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.followerId == request.auth.uid;
    }

    // ── Notifications ─────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Payments ──────────────────────────────────────
    match /payments/{payId} {
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Payment Requests ──────────────────────────────
    match /paymentRequests/{reqId} {
      allow read: if isAuth()
        && (resource.data.requestedBy == request.auth.uid || isAdmin() || isCashier());
      allow create: if isAuth()
        && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isAdmin() || isCashier();
      allow delete: if isAdmin();
    }

    // ── Video Payments ────────────────────────────────
    match /videoPayments/{reqId} {
      allow read: if isAuth()
        && (resource.data.requestedBy == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Jobs ──────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth()
        && (resource.data.employerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Applications ──────────────────────────────────
    match /applications/{appId} {
      allow read: if isAuth()
        && (resource.data.applicantId == request.auth.uid
            || resource.data.employerId == request.auth.uid
            || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Connections ───────────────────────────────────
    match /connections/{conId} {
      allow read: if isAuth()
        && (resource.data.seekerId == request.auth.uid
            || resource.data.employerId == request.auth.uid
            || isAdmin());
      allow create: if isAuth();
      allow update: if isAuth()
        && (resource.data.seekerId == request.auth.uid
            || resource.data.employerId == request.auth.uid
            || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Admin Settings ────────────────────────────────
    match /adminSettings/{doc} {
      allow read, write: if isAdmin();
    }

    // ── Likes (Fallback rule) ─────────────────────────
    match /likes/{likeId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ── Video Feedback (Not Interested etc) ───────────
    match /video_feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── Reports ───────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth() && request.resource.data.reportedBy == request.auth.uid;
    }

    // ── Interests ─────────────────────────────────────
    match /interests/{interestId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}
