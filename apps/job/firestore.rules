rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users ─────────────────────────────────────────
    match /users/{uid} {
      // Anyone can read profiles (for public profiles):
      allow read: if true;

      // Only owner can create their own profile:
      allow create: if isOwner(uid);

      // Owner can update their own profile.
      // Also allow updating followerCount/followingCount from any
      // authenticated user (for follow system):
      allow update: if isOwner(uid)
        || (isAuth() && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['followerCount', 'followingCount',
                      'watchedVideos', 'likedVideos',
                      'savedVideos', 'interestedVideos', 'notInterestedVideos']));

      allow delete: if isAdmin();
    }

    // ── Videos ───────────────────────────────────────
    match /videos/{videoId} {
      // Anyone can read approved live videos:
      allow read: if resource.data.is_live == true
        && resource.data.admin_status == 'approved';

      // Auth users can read their own videos (any status):
      allow read: if isAuth()
        && resource.data.userId == request.auth.uid;

      // Admin can read all:
      allow read: if isAdmin();

      // Auth users can create videos:
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;

      // Owner can update their own video:
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid;

      // Allow incrementing views + likes from any authenticated user:
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['views', 'likes', 'likedBy']);

      // Admin can update anything:
      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // ── Follows ───────────────────────────────────────
    match /follows/{followId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.followerId == request.auth.uid;
    }

    // ── Notifications ─────────────────────────────────
    match /notifications/{notifId} {
      // User can read their own notifications:
      allow read: if isAuth()
        && resource.data.userId == request.auth.uid;
      // Anyone auth can create notifications (for follow/like events):
      allow create: if isAuth();
      // User can update own (mark as read):
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.userId == request.auth.uid;
    }

    // ── Payment Requests ──────────────────────────────
    match /paymentRequests/{reqId} {
      allow read: if isAuth()
        && (resource.data.requestedBy == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Admin-only collections ────────────────────────
    match /adminSettings/{doc} {
      allow read, write: if isAdmin();
    }
  }
}