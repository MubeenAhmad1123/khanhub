rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    //  SHARED HELPERS  (job platform — do not modify)
    // ═══════════════════════════════════════════════════════════

    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('role', '') == 'admin';
    }
    function isCashier() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('role', '') == 'cashier';
    }

    // ═══════════════════════════════════════════════════════════
    //  JOB PLATFORM COLLECTIONS  (unchanged — do not modify)
    // ═══════════════════════════════════════════════════════════

    // ── Users ─────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        || isAdmin()
        || (isAuth() && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly([
              'followerCount', 'followingCount',
              'likedVideos', 'savedVideos',
              'interestedVideos', 'notInterestedVideos',
              'totalLikes', 'watchedVideos'
            ]));
      allow delete: if isAdmin();
    }

    // ── Videos ───────────────────────────────────────
    match /videos/{videoId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid)
        || (isAuth() && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['views', 'likes', 'likedBy']));
      allow delete: if isAdmin();
    }

    // ── Follows ───────────────────────────────────────
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.followerId == request.auth.uid;
    }

    // ── Notifications ─────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Payments ──────────────────────────────────────
    match /payments/{payId} {
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Payment Requests ──────────────────────────────
    match /paymentRequests/{reqId} {
      allow read: if isAuth()
        && (resource.data.requestedBy == request.auth.uid || isAdmin() || isCashier());
      allow create: if isAuth()
        && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isAdmin() || isCashier();
      allow delete: if isAdmin();
    }

    // ── Video Payments ────────────────────────────────
    match /videoPayments/{reqId} {
      allow read: if isAuth()
        && (resource.data.requestedBy == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Jobs ──────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth()
        && (resource.data.employerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Applications ──────────────────────────────────
    match /applications/{appId} {
      allow read: if isAuth()
        && (resource.data.applicantId == request.auth.uid
            || resource.data.employerId == request.auth.uid
            || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Connections ───────────────────────────────────
    match /connections/{conId} {
      allow read: if isAuth()
        && (resource.data.seekerId == request.auth.uid
            || resource.data.employerId == request.auth.uid
            || isAdmin());
      allow create: if isAuth();
      allow update: if isAuth()
        && (resource.data.seekerId == request.auth.uid
            || resource.data.employerId == request.auth.uid
            || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Admin Settings ────────────────────────────────
    match /adminSettings/{doc} {
      allow read, write: if isAdmin();
    }

    // ── Likes (Fallback rule) ─────────────────────────
    match /likes/{likeId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ── Video Feedback ────────────────────────────────
    match /video_feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Reports ───────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth()
        && request.resource.data.reportedBy == request.auth.uid;
    }

    // ── Interests ─────────────────────────────────────
    match /interests/{interestId} {
      allow read: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════
    //  REHAB PORTAL HELPERS
    //  Separate from job platform — uses rehab_users collection
    //  The isAdmin() above checks /users/ — these check /rehab_users/
    // ═══════════════════════════════════════════════════════════

    function isRehabAuth() {
      return request.auth != null
        && exists(/databases/$(database)/documents/rehab_users/$(request.auth.uid));
    }
    function rehabRole() {
      return get(/databases/$(database)/documents/rehab_users/$(request.auth.uid)).data.role;
    }
    function isRehabRole(role) {
      return isRehabAuth() && rehabRole() == role;
    }
    function isRehabAdminOrAbove() {
      return isRehabAuth()
        && (rehabRole() == 'admin' || rehabRole() == 'superadmin');
    }
    function isRehabSuperAdmin() {
      return isRehabRole('superadmin');
    }
    function rehabPatientId() {
      return get(/databases/$(database)/documents/rehab_users/$(request.auth.uid)).data.patientId;
    }
    function rehabStaffId() {
      return get(/databases/$(database)/documents/rehab_users/$(request.auth.uid)).data.staffId;
    }
    function isOwnStaffRecord(staffId) {
      return isRehabRole('staff')
        && (staffId == request.auth.uid || staffId == rehabStaffId());
    }

    // ═══════════════════════════════════════════════════════════
    //  HQ PORTAL HELPERS
    //  HQ is the master dashboard — separate from rehab portal
    //  Roles: superadmin, manager, superintendent
    // ═══════════════════════════════════════════════════════════

    function isHQAuth() {
      return isHqAuth();
    }
    function isHQManagerOrAbove() {
      return isHqSuperOrManager();
    }
    function isHQSuperAdmin() {
      return isHqSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    //  REHAB PORTAL COLLECTIONS
    // ═══════════════════════════════════════════════════════════

    // ── Setup meta (one-time init flag) ───────────────
    // Public read so setup page can check if system is initialized.
    // Write is false from client — only server action (Firebase Admin) writes this.
    match /rehab_meta/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ── Rehab user profiles ────────────────────────────
    // Users can read their own profile.
    // Admin/superadmin can read all.
    // Write is false from client — only server action (Firebase Admin) creates/updates.
    match /rehab_users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isRehabAdminOrAbove());
      allow create: if false;
      allow delete: if false;
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['photoUrl', 'displayName', 'phone']);
    }

    // ── Patients ───────────────────────────────────────
    // Family can only read their linked patient.
    // Admin/superadmin can read and write all.
    // Delete only by superadmin.
    match /rehab_patients/{patientId} {
      allow read: if isRehabAdminOrAbove()
        || isRehabRole('cashier')
        || (isRehabRole('family') && rehabPatientId() == patientId);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Fee records ────────────────────────────────────
    // Family can read only their patient's fee record.
    // Cashier and superadmin can write.
    // Admin can read all (for reports).
    match /rehab_fees/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('cashier'))
        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId);
      allow write: if isRehabRole('cashier') || isRehabSuperAdmin();
    }

    // ── Canteen records ────────────────────────────────
    match /rehab_canteen/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('cashier'))
        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId);
      allow write: if isRehabRole('cashier') || isRehabSuperAdmin();
    }

    // ── Rehab salary records ───────────────────────────
    // Superadmin/admin create and approve staff salary payment records.
    match /rehab_salary_records/{docId} {
      allow read: if isRehabAdminOrAbove();
      allow write: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Transactions ───────────────────────────────────
    // Cashier creates. Superadmin approves/rejects (update).
    // Admin can create pending requests (admin enters amount).
    // Superadmin approves/rejects (update). Cashier forwards requests (update).
    // Nobody deletes transactions — full audit trail.
    match /rehab_transactions/{docId} {
      allow read: if isRehabAdminOrAbove() || isRehabRole('cashier');
      allow create: if isRehabRole('cashier')
        || isRehabSuperAdmin()
        || (isRehabAdminOrAbove() && request.resource.data.status == 'pending_cashier');
      allow update: if isRehabSuperAdmin()
        || (
          isRehabRole('cashier')
          && resource.data.status == 'pending_cashier'
          && request.resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'proofUrl',
            'proofMissingReason',
            'proofRequired',
            'cashierForwardedAt',
            'cashierForwardedBy',
            'cashierForwardedByName'
          ])
        );
      allow delete: if false;
    }

    // ── Staff profiles ─────────────────────────────────
    // Staff can read their own profile only.
    // Admin/superadmin can read and write all.
    match /rehab_staff/{staffId} {
      allow read: if isRehabAdminOrAbove()
        || isRehabRole('cashier')
        || (isRehabRole('staff') && rehabStaffId() == staffId)
        || isHQManagerOrAbove();
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Attendance ─────────────────────────────────────
    // Staff can create their own attendance (self check-in).
    // Admin can update (override). Nobody deletes.
    match /rehab_attendance/{docId} {
      allow read: if isRehabAdminOrAbove()
        || isRehabRole('cashier')
        || isRehabRole('staff')
        || isHQManagerOrAbove();
      allow create: if isRehabRole('staff') || isRehabAdminOrAbove();
      allow update: if isRehabRole('staff') || isRehabAdminOrAbove();
      allow delete: if false;
    }

    // ── Patient videos ─────────────────────────────────
    // Family can read only their patient's videos.
    // Admin/superadmin can read and write all.
    match /rehab_videos/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Patient visits ─────────────────────────────────
    // Family can read only their patient's visits.
    // Admin/superadmin can read and write all.
    match /rehab_visits/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Audit log ──────────────────────────────────────
    // Only superadmin can read. 
    // Server actions write via Admin SDK (bypasses rules).
    // Client writes allowed for fire-and-forget audit entries
    // from authenticated rehab users only.
    match /rehab_audit/{docId} {
      allow read: if isRehabSuperAdmin();
      allow create: if isRehabAuth();
      allow update, delete: if false;
    }

    // ── Staff contributions ────────────────────────────
    match /rehab_contributions/{docId} {
      allow read: if isRehabRole('admin')
        || isHqSuperOrManager()
        || isOwnStaffRecord(resource.data.staffId);
      allow create: if isRehabRole('staff') || isRehabRole('admin');
      allow update: if isRehabRole('admin') || isHqSuperOrManager()
        || (isOwnStaffRecord(resource.data.staffId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content']));
      allow delete: if false;
    }

    // ── Staff fines ────────────────────────────────────
    // Admin/superadmin read and write. Staff reads own fines.
    match /rehab_fines/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('staff') 
            && resource.data.staffId == request.auth.uid);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Staff leaves ───────────────────────────────────
    // Admin/superadmin read and write. Staff reads own leaves.
    match /rehab_leaves/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('staff') 
            && resource.data.staffId == request.auth.uid);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Duty Logs ─────────────────────────────────────────────────────────────
    match /rehab_duty_logs/{docId} {
      allow read: if isRehabRole('admin')
        || isHqSuperOrManager()
        || isOwnStaffRecord(resource.data.staffId);
      allow create, update: if isRehabRole('admin') || isHqSuperOrManager();
      allow delete: if false;
    }

    // ── Dress Logs ────────────────────────────────────────────────────────────
    match /rehab_dress_logs/{docId} {
      allow read: if isRehabRole('admin')
        || isHqSuperOrManager()
        || isOwnStaffRecord(resource.data.staffId);
      allow create, update: if isRehabRole('admin') || isHqSuperOrManager();
      allow delete: if false;
    }

    // ── Growth Points ─────────────────────────────────────────────────────────
    match /rehab_growth_points/{docId} {
      allow read: if isRehabRole('admin')
        || isHqSuperOrManager()
        || isOwnStaffRecord(resource.data.staffId);
      allow create, update: if isRehabRole('admin') || isHqSuperOrManager();
      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════
    //  SPIMS COLLEGE PORTAL HELPERS
    // ═══════════════════════════════════════════════════════════

    function isSpimsAuth() {
      return request.auth != null
        && exists(/databases/$(database)/documents/spims_users/$(request.auth.uid));
    }
    function spimsRole() {
      return get(/databases/$(database)/documents/spims_users/$(request.auth.uid)).data.role;
    }
    function isSpimsRole(role) {
      return isSpimsAuth() && spimsRole() == role;
    }
    function isSpimsAdminOrAbove() {
      return isSpimsAuth()
        && (spimsRole() == 'admin' || spimsRole() == 'superadmin');
    }
    function isSpimsSuperAdmin() {
      return isSpimsRole('superadmin');
    }
    function spimsStudentId() {
      return get(/databases/$(database)/documents/spims_users/$(request.auth.uid)).data.studentId;
    }
    function spimsStaffId() {
      return get(/databases/$(database)/documents/spims_users/$(request.auth.uid)).data.staffId;
    }

    // ═══════════════════════════════════════════════════════════
    //  SPIMS COLLEGE PORTAL COLLECTIONS
    // ═══════════════════════════════════════════════════════════

    match /spims_meta/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /spims_users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isSpimsAdminOrAbove());
      allow create: if false;
      allow delete: if false;
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['photoUrl', 'displayName', 'phone']);
    }

    match /spims_students/{studentId} {
      allow read: if isSpimsAdminOrAbove()
        || isSpimsRole('cashier')
        || (isSpimsRole('student') && spimsStudentId() == studentId);
      allow create, update: if isSpimsAdminOrAbove();
      allow delete: if isSpimsSuperAdmin();
    }

    match /spims_fees/{docId} {
      allow read: if isSpimsAdminOrAbove()
        || (isSpimsRole('cashier'))
        || (isSpimsRole('student') && spimsStudentId() == resource.data.studentId);
      allow write: if isSpimsRole('cashier') || isSpimsSuperAdmin();
    }

    // Student specific records (similar to patient records)
    match /spims_board_fees/{docId} {
      allow read: if isSpimsAdminOrAbove()
        || (isSpimsRole('cashier'))
        || (isSpimsRole('student') && spimsStudentId() == resource.data.studentId);
      allow write: if isSpimsRole('cashier') || isSpimsSuperAdmin();
    }

    match /spims_exams/{docId} {
      allow read: if isSpimsAdminOrAbove()
        || (isSpimsRole('student') && spimsStudentId() == resource.data.studentId);
      allow create, update: if isSpimsAdminOrAbove();
      allow delete: if isSpimsSuperAdmin();
    }

    match /spims_transactions/{docId} {
      allow read: if isSpimsAdminOrAbove() || isSpimsRole('cashier');
      allow create: if isSpimsRole('cashier') || isSpimsSuperAdmin();
      allow update: if isSpimsSuperAdmin();
      allow delete: if false;
    }

    match /spims_staff/{staffId} {
      allow read: if isSpimsAdminOrAbove()
        || isSpimsRole('cashier')
        || (isSpimsRole('staff') && spimsStaffId() == staffId);
      allow create, update: if isSpimsAdminOrAbove();
      allow delete: if isSpimsSuperAdmin();
    }

    match /spims_attendance/{docId} {
      allow read: if isSpimsAdminOrAbove()
        || isSpimsRole('cashier')
        || isSpimsRole('staff');
      allow create, update: if isSpimsRole('staff') || isSpimsAdminOrAbove();
      allow delete: if false;
    }

    match /spims_audit/{docId} {
      allow read: if isSpimsSuperAdmin();
      allow create: if isSpimsAuth();
      allow update, delete: if false;
    }

    match /spims_salary_records/{docId} {
      allow read: if isSpimsAdminOrAbove() || isSpimsRole('cashier');
      allow create: if isSpimsSuperAdmin();
      allow update: if isSpimsSuperAdmin();
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════ 
    //  HQ PORTAL HELPERS 
    //  Global system: superadmin, manager, cashier 
    //  Uses hq_users collection (doc ID = Firebase Auth uid) 
    // ═══════════════════════════════════════════════════════════ 

    function isHqAuth() { 
      return request.auth != null 
        && exists(/databases/$(database)/documents/hq_users/$(request.auth.uid)); 
    } 
    function hqRole() { 
      return get(/databases/$(database)/documents/hq_users/$(request.auth.uid)).data.role; 
    } 
    function isHqRole(role) { 
      return isHqAuth() && hqRole() == role; 
    } 
    function isHqSuperAdmin() { 
      return isHqRole('superadmin'); 
    } 
    function isHqManager() { 
      return isHqRole('manager'); 
    } 
    function isHqCashier() { 
      return isHqRole('cashier'); 
    } 
    function isHqSuperOrManager() { 
      return isHqAuth() && (hqRole() == 'superadmin' || hqRole() == 'manager'); 
    } 
    function isHqTier1() { 
      return isHqAuth() && hqRole() in ['superadmin', 'manager', 'cashier']; 
    } 

    // ═══════════════════════════════════════════════════════════ 
    //  HQ PORTAL COLLECTIONS 
    // ═══════════════════════════════════════════════════════════ 

    // hq_meta — one-time setup flag 
    // Public read so setup page can check initialization status. 
    // Write: Firebase Admin SDK only (server action). 
    match /hq_meta/{docId} { 
      allow read: if true; 
      allow write: if false; 
    } 

    // hq_users — superadmin / manager / cashier profiles
    // Read: own doc OR any HQ tier1 user.
    // Create/Delete: server-side (Admin SDK) only.
    // Update:
    //  - superadmin/manager can update users (e.g. isActive)
    //  - owner can update limited profile fields only
    match /hq_users/{docId} {
      allow read: if isHqAuth() && (request.auth.uid == docId || isHqTier1());
      allow create, delete: if false;
      allow update: if isHqSuperOrManager()
        || (
          isHqAuth()
          && request.auth.uid == docId
          && request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasOnly(['photoUrl', 'name', 'phone'])
        );
    }

    // hq_staff — global staff profiles across all departments 
    // Read: any HQ tier1 OR rehab/spims admin 
    // Write: superadmin or manager only 
    match /hq_staff/{staffId} { 
      allow read: if isHqSuperOrManager(); 
      allow create: if isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
      allow delete: if isHqSuperAdmin(); 
    } 

    // hq_attendance — staff attendance records (marked by manager only) 
    // Staff CANNOT mark own attendance — manager does it. 
    // Staff can read their own record. Manager/superadmin read+write all. 
    match /hq_attendance/{docId} { 
      allow read: if isHqSuperOrManager(); 
      allow create: if isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
      allow delete: if isHqSuperAdmin(); 
    } 

    // ── Departmental Staff Operational Rules (Rehab, SPIMS, etc.) ─────────────────

    // Patterns: {dept}_dress_code, {dept}_duty_log, {dept}_staff_dress_config, {dept}_staff_duty_config
    
    // REHAB
    match /rehab_dress_code/{docId} {
      allow read: if isHqSuperOrManager() || (isRehabAuth() && resource.data.staffId == request.auth.uid);
      allow write: if isHqSuperOrManager();
    }
    match /rehab_duty_log/{docId} {
      allow read: if isHqSuperOrManager() || (isRehabAuth() && resource.data.staffId == request.auth.uid);
      allow write: if isHqSuperOrManager();
    }
    match /rehab_staff_dress_config/{docId} {
      allow read: if isAuth(); // Any authenticated user can read config
      allow write: if isHqSuperOrManager();
    }
    match /rehab_staff_duty_config/{docId} {
      allow read: if isAuth();
      allow write: if isHqSuperOrManager();
    }

    // SPIMS
    match /spims_dress_code/{docId} {
      allow read: if isHqSuperOrManager() || (isSpimsAuth() && resource.data.staffId == request.auth.uid);
      allow write: if isHqSuperOrManager();
    }
    match /spims_duty_log/{docId} {
      allow read: if isHqSuperOrManager() || (isSpimsAuth() && resource.data.staffId == request.auth.uid);
      allow write: if isHqSuperOrManager();
    }
    match /spims_staff_dress_config/{docId} {
      allow read: if isAuth();
      allow write: if isHqSuperOrManager();
    }
    match /spims_staff_duty_config/{docId} {
      allow read: if isAuth();
      allow write: if isHqSuperOrManager();
    }

    // hq_targets — monthly targets assigned to admin/staff 
    match /hq_targets/{docId} { 
      allow read: if isHqSuperOrManager() 
        || (request.auth != null && resource.data.staffId == request.auth.uid); 
      allow create: if isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
      allow delete: if isHqSuperAdmin(); 
    } 

    // hq_salary_records — staff salary payment records 
    match /hq_salary_records/{docId} { 
      allow read: if isHqSuperOrManager() 
        || (request.auth != null && resource.data.staffId == request.auth.uid); 
      allow create: if isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
      allow delete: if isHqSuperAdmin(); 
    } 

    // hq_cashier_categories — reusable custom income/expense fields
    // Cashier/manager/superadmin can read and create.
    // Manager/superadmin can edit/delete for governance.
    match /hq_cashier_categories/{docId} {
      allow read: if isHqTier1();
      allow create: if isHqTier1();
      allow update, delete: if isHqSuperOrManager();
    }

    // hq_fines — late/discipline fines auto-created on attendance 
    match /hq_fines/{docId} { 
      allow read: if isHqSuperOrManager() 
        || (request.auth != null && resource.data.staffId == request.auth.uid); 
      allow create: if isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
      allow delete: if isHqSuperAdmin(); 
    } 

    // hq_audit — cross-system audit log 
    match /hq_audit/{docId} { 
      allow read: if isHqSuperAdmin(); 
      allow create: if request.auth != null; 
    } 

    // hq_ledger_entries — immutable canonical ledger
    // Written by server action (Admin SDK) on every superadmin approval.
    // HQ tier1 can read. Nobody deletes or updates from client.
    match /hq_ledger_entries/{docId} {
      allow read: if isHqTier1();
      allow create: if isHqSuperAdmin();
      allow update, delete: if false;
    }

    // hq_reconciliation — daily cashier close records
    // Cashier creates. Superadmin/manager reads and verifies.
    // Nobody edits or deletes.
    match /hq_reconciliation/{docId} {
      allow read: if isHqSuperOrManager();
      allow create: if isHqCashier() || isHqSuperOrManager();
      allow update, delete: if false;
    }

    // hq_growth_points — points system for HQ staff
    match /hq_growth_points/{docId} { 
      allow read: if isHqSuperOrManager() 
        || (request.auth != null && resource.data.staffId == request.auth.uid); 
      allow create, update: if isHqSuperOrManager(); 
      allow delete: if isHqSuperAdmin(); 
    } 

    // ── Cross-department transaction access for HQ roles ────── 
    // Manager needs to read+approve transactions from both rehab and spims. 
    // Cashier needs to create transactions in both. 
    // These rules EXTEND the existing rehab_transactions and spims_transactions 
    // rules above — Firestore merges them (most permissive wins). 

    match /rehab_transactions/{docId} { 
      allow read: if isHqTier1(); 
      allow create: if isHqCashier() || isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager()
        || (
          isHqCashier()
          && resource.data.status == 'pending_cashier'
          && request.resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'proofUrl',
            'proofMissingReason',
            'proofRequired',
            'cashierForwardedAt',
            'cashierForwardedBy',
            'cashierForwardedByName'
          ])
        );
    } 

    match /rehab_fees/{docId} { 
      allow read: if isHqTier1(); 
      allow create: if isHqCashier() || isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
    } 

    match /rehab_patients/{patientId} { 
      allow read: if isHqTier1(); 
      allow create: if isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
    } 

    match /rehab_canteen/{docId} { 
      allow read: if isHqTier1(); 
      allow create: if isHqCashier() || isHqSuperOrManager(); 
      allow update: if isHqCashier() || isHqSuperOrManager(); 
    } 

    // HQ overlay: staff salary payment records created/approved from HQ.
    match /rehab_salary_records/{docId} {
      allow read: if isHqTier1();
      allow create, update: if isHqSuperOrManager();
      allow delete: if isHqSuperAdmin();
    }

    match /rehab_staff/{staffId} { 
      allow read: if isHqSuperOrManager(); 
      allow create: if isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
    } 

    match /rehab_users/{uid} { 
      allow read: if isHqTier1(); 
      allow update: if isHqSuperAdmin(); 
    } 

    match /rehab_reports/{docId} { 
      allow read: if isHqTier1(); 
      allow create: if isHqTier1(); 
      allow update: if isHqSuperOrManager(); 
      allow delete: if isHqSuperAdmin(); 
    } 

    match /spims_transactions/{docId} { 
      allow read: if isHqTier1(); 
      allow create: if isHqCashier() || isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
    } 

    match /spims_fees/{docId} { 
      allow read: if isHqTier1(); 
      allow create: if isHqCashier() || isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
    } 

    match /spims_students/{studentId} { 
      allow read: if isHqTier1(); 
      allow create: if isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
    } 

    match /spims_staff/{staffId} { 
      allow read: if isHqSuperOrManager(); 
      allow create: if isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
    } 

    match /spims_users/{uid} { 
      allow read: if isHqTier1(); 
      allow update: if isHqSuperAdmin(); 
    }

    match /rehab_attendance/{docId} {
      allow read: if isHqSuperOrManager();
      allow create, update: if isHqSuperOrManager();
    }

    match /spims_attendance/{docId} {
      allow read: if isHqSuperOrManager();
      allow create, update: if isHqSuperOrManager();
    }

    // ── Daily Activity Records ─────────────────────────────────────────────────
    match /rehab_daily_activities/{docId} {
      allow read: if isRehabRole('admin')
        || isHqTier1()
        || (isRehabRole('family') && resource.data.patientId == rehabPatientId());
      allow create, update: if isRehabRole('admin') || isHqSuperOrManager();
      allow delete: if false;
    }

    // ── Therapy Sessions ──────────────────────────────────────────────────────
    match /rehab_therapy_sessions/{docId} {
      allow read: if isRehabRole('admin')
        || isHqTier1()
        || (isRehabRole('family') && resource.data.patientId == rehabPatientId());
      allow create, update: if isRehabRole('admin') || isHqSuperOrManager();
      allow delete: if false;
    }

    // ── Medication Records ────────────────────────────────────────────────────
    match /rehab_medication_records/{docId} {
      allow read: if isRehabRole('admin')
        || isHqTier1()
        || (isRehabRole('family') && resource.data.patientId == rehabPatientId());
      allow create, update: if isRehabRole('admin') || isHqSuperOrManager();
      allow delete: if false;
    }

    // ── Weekly Progress ───────────────────────────────────────────────────────
    match /rehab_weekly_progress/{docId} {
      allow read: if isRehabRole('admin')
        || isHqTier1()
        || (isRehabRole('family') && resource.data.patientId == rehabPatientId());
      allow create, update: if isRehabRole('admin') || isHqSuperOrManager();
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════
    //  HQ PORTAL COLLECTIONS
    // ═══════════════════════════════════════════════════════════

    // ── HQ Staff profiles ──────────────────────────────
    // Manager and superadmin can read and edit all staff.
    // Staff can read their own profile only.
    match /hq_staff/{staffId} {
      allow read: if isHQManagerOrAbove();
      allow create, update: if isHQManagerOrAbove();
      allow delete: if isHQSuperAdmin();
    }

    // ── HQ Attendance ──────────────────────────────────
    // Manager and superadmin can read all attendance.
    // Nobody deletes attendance — full audit trail.
    match /hq_attendance/{docId} {
      allow read: if isHQManagerOrAbove();
      allow create, update: if isHQManagerOrAbove();
      allow delete: if false;
    }

    // ── Rehab Duty Logs ────────────────────────────────
    // Manager and superadmin can read all. Rehab admin can also read.
    match /rehab_duty_logs/{docId} {
      allow read: if isRehabAdminOrAbove() || isHQManagerOrAbove();
      allow create, update: if isRehabAdminOrAbove() || isHQManagerOrAbove();
      allow delete: if false;
    }

    // ── HQ Duty Logs ───────────────────────────────────
    // Manager and superadmin can read and write all.
    match /hq_duty_logs/{docId} {
      allow read: if isHQManagerOrAbove();
      allow create, update: if isHQManagerOrAbove();
      allow delete: if false;
    }

    // ── Future departments staff-management (manager/superadmin only) ────────
    // Any new department that follows naming:
    //   {dept}_staff, {dept}_attendance, {dept}_duty_logs
    // is automatically manageable from HQ by manager/superadmin.
    match /{collectionId}/{docId} {
      allow read, create, update: if isHqSuperOrManager()
        && (
          collectionId.matches('^[a-z0-9]+_staff$')
          || collectionId.matches('^[a-z0-9]+_attendance$')
          || collectionId.matches('^[a-z0-9]+_duty_logs$')
        );
      allow delete: if isHqSuperAdmin()
        && collectionId.matches('^[a-z0-9]+_staff$');
    }

  }
}



