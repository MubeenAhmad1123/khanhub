    // ═══════════════════════════════════════════════════════════
    //  JOB CENTER PORTAL HELPERS
    // ═══════════════════════════════════════════════════════════

    function isJobCenterAuth() {
      return request.auth != null
        && (exists(/databases/$(database)/documents/job_center_users/$(request.auth.uid))
            || exists(/databases/$(database)/documents/jobcenter_users/$(request.auth.uid)));
    }
    function jobCenterRole() {
      return exists(/databases/$(database)/documents/job_center_users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/job_center_users/$(request.auth.uid)).data.role
        : get(/databases/$(database)/documents/jobcenter_users/$(request.auth.uid)).data.role;
    }
    function isJobCenterRole(role) {
      return isJobCenterAuth() && jobCenterRole() == role;
    }
    function isJobCenterAdminOrAbove() {
      return isJobCenterAuth()
        && (jobCenterRole() == 'admin' || jobCenterRole() == 'superadmin');
    }
    function isJobCenterSuperAdmin() {
      return isJobCenterRole('superadmin');
    }
    function jobCenterSeekerId() {
      return exists(/databases/$(database)/documents/job_center_users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/job_center_users/$(request.auth.uid)).data.seekerId
        : get(/databases/$(database)/documents/jobcenter_users/$(request.auth.uid)).data.seekerId;
    }
    function jobCenterStaffId() {
      return exists(/databases/$(database)/documents/job_center_users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/job_center_users/$(request.auth.uid)).data.staffId
        : get(/databases/$(database)/documents/jobcenter_users/$(request.auth.uid)).data.staffId;
    }

