    match /job_center_users/{uid} {
      allow read: if (request.auth != null
        && (request.auth.uid == uid || isJobCenterAdminOrAbove()))
        || isHqSuperOrManager();
      allow create: if isJobCenterSuperAdmin() || isHqSuperOrManager();
      allow delete: if isJobCenterSuperAdmin() || isHqSuperOrManager();
      allow update: if (request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['photoUrl', 'displayName', 'phone']))
        || isHqSuperOrManager();
    }

    match /jobcenter_users/{uid} {
      allow read: if (request.auth != null
        && (request.auth.uid == uid || isJobCenterAdminOrAbove()))
