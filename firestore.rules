    match /sukoon_staff_duty_config/{docId} {
      allow read: if isAuth();
      allow write: if isHqSuperOrManager();
    }

    match /welfare_dress_code/{docId} {
      allow read: if isHqSuperOrManager() || (isWelfareAuth() && resource.data.staffId == request.auth.uid);
      allow write: if isHqSuperOrManager();
    }
    match /welfare_duty_log/{docId} {
      allow read: if isHqSuperOrManager() || (isWelfareAuth() && resource.data.staffId == request.auth.uid);
      allow write: if isHqSuperOrManager();
    }
    match /welfare_staff_dress_config/{docId} {
      allow read: if isAuth();
      allow write: if isHqSuperOrManager();
    }
    match /welfare_staff_duty_config/{docId} {
      allow read: if isAuth();
      allow write: if isHqSuperOrManager();
    }

    match /job_center_dress_code/{docId} {
      allow read: if isHqSuperOrManager() || (isJobCenterAuth() && resource.data.staffId == request.auth.uid);
      allow write: if isHqSuperOrManager();
    }
    match /job_center_duty_log/{docId} {
      allow read: if isHqSuperOrManager() || (isJobCenterAuth() && resource.data.staffId == request.auth.uid);
      allow write: if isHqSuperOrManager();
    }
    match /job_center_staff_dress_config/{docId} {
      allow read: if isAuth();
      allow write: if isHqSuperOrManager();
    }
    match /job_center_staff_duty_config/{docId} {
      allow read: if isAuth();
      allow write: if isHqSuperOrManager();
    }

  }
}



