rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    //  SHARED HELPERS  (job platform — do not modify)
    // ═══════════════════════════════════════════════════════════

    function isAuth() {
      return request.auth != null;
    }
    function isDiscoveryQuery() {
      return request.query.limit != null && request.query.limit <= 1;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('role', '') == 'admin';
    }
    function isCashier() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('role', '') == 'cashier';
    }

    // ═══════════════════════════════════════════════════════════
    //  JOB PLATFORM COLLECTIONS  (unchanged — do not modify)
    // ═══════════════════════════════════════════════════════════

    // ── Users ─────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        || isAdmin()
        || (isAuth() && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly([
              'followerCount', 'followingCount',
              'likedVideos', 'savedVideos',
              'interestedVideos', 'notInterestedVideos',
              'totalLikes', 'watchedVideos'
            ]));
      allow delete: if isAdmin();
    }

    // ── Videos ───────────────────────────────────────
    match /videos/{videoId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid)
        || (isAuth() && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['views', 'likes', 'likedBy']));
      allow delete: if isAdmin();
    }

    // ── Follows ───────────────────────────────────────
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.followerId == request.auth.uid;
    }

    // ── Notifications ─────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Payments ──────────────────────────────────────
    match /payments/{payId} {
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Payment Requests ──────────────────────────────
    match /paymentRequests/{reqId} {
      allow read: if isAuth()
        && (resource.data.requestedBy == request.auth.uid || isAdmin() || isCashier());
      allow create: if isAuth()
        && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isAdmin() || isCashier();
      allow delete: if isAdmin();
    }

    // ── Video Payments ────────────────────────────────
    match /videoPayments/{reqId} {
      allow read: if isAuth()
        && (resource.data.requestedBy == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Jobs ──────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth()
        && (resource.data.employerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Applications ──────────────────────────────────
    match /applications/{appId} {
      allow read: if isAuth()
        && (resource.data.applicantId == request.auth.uid
            || resource.data.employerId == request.auth.uid
            || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Connections ───────────────────────────────────
    match /connections/{conId} {
      allow read: if isAuth()
        && (resource.data.seekerId == request.auth.uid
            || resource.data.employerId == request.auth.uid
            || isAdmin());
      allow create: if isAuth();
      allow update: if isAuth()
        && (resource.data.seekerId == request.auth.uid
            || resource.data.employerId == request.auth.uid
            || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Admin Settings ────────────────────────────────
    match /adminSettings/{doc} {
      allow read, write: if isAdmin();
    }

    // ── Likes (Fallback rule) ─────────────────────────
    match /likes/{likeId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ── Video Feedback ────────────────────────────────
    match /video_feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Reports ───────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth()
        && request.resource.data.reportedBy == request.auth.uid;
    }

    // ── Interests ─────────────────────────────────────
    match /interests/{interestId} {
      allow read: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════
    //  REHAB PORTAL HELPERS
    //  Separate from job platform — uses rehab_users collection
    //  The isAdmin() above checks /users/ — these check /rehab_users/
    // ═══════════════════════════════════════════════════════════

    function isRehabAuth() {
      return request.auth != null
        && exists(/databases/$(database)/documents/rehab_users/$(request.auth.uid));
    }
    function rehabRole() {
      return get(/databases/$(database)/documents/rehab_users/$(request.auth.uid)).data.role;
    }
    function isRehabRole(role) {
      return isRehabAuth() && rehabRole() == role;
    }
    function isRehabAdminOrAbove() {
      return isRehabAuth()
        && (rehabRole() == 'admin' || rehabRole() == 'superadmin');
    }
    function isRehabSuperAdmin() {
      return isRehabRole('superadmin');
    }
    function rehabPatientId() {
      return get(/databases/$(database)/documents/rehab_users/$(request.auth.uid)).data.patientId;
    }
    function rehabStaffId() {
      return get(/databases/$(database)/documents/rehab_users/$(request.auth.uid)).data.staffId;
    }
    function isOwnStaffRecord(staffId) {
      return isRehabRole('staff')
        && (staffId == request.auth.uid || staffId == rehabStaffId());
    }


    // ── Rehab portal helpes ───────────────

    // ═══════════════════════════════════════════════════════════
    //  REHAB PORTAL COLLECTIONS
    // ═══════════════════════════════════════════════════════════

    // ── Setup meta (one-time init flag) ───────────────
    // Public read so setup page can check if system is initialized.
    // Write is false from client — only server action (Firebase Admin) writes this.
    match /rehab_meta/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ── Rehab user profiles ────────────────────────────
    // Users can read their own profile.
    // Admin/superadmin can read all.
    // Write is false from client — only server action (Firebase Admin) creates/updates.
    match /rehab_users/{uid} {
      allow read: if (request.auth != null
        && (request.auth.uid == uid || isRehabAdminOrAbove()))
        || isDiscoveryQuery();
      allow create: if isRehabSuperAdmin() || isHqSuperOrManager();
      allow delete: if isRehabSuperAdmin() || isHqSuperOrManager();
      allow update: if (request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['photoUrl', 'displayName', 'phone']))
        || isHqSuperOrManager();
    }

    // ── Patients ───────────────────────────────────────
    // Family can only read their linked patient.
    // Admin/superadmin can read and write all.
    // Delete only by superadmin.
    match /rehab_patients/{patientId} {
      allow read: if isRehabAdminOrAbove()
        || isRehabRole('cashier')
        || (isRehabRole('family') && rehabPatientId() == patientId);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Fee records ────────────────────────────────────
    // Family can read only their patient's fee record.
    // Cashier and superadmin can write.
    // Admin can read all (for reports).
    match /rehab_fees/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('cashier'))
        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId)
        || isHqSuperAdmin();
      allow create, update: if isRehabRole('cashier') || isRehabSuperAdmin() || isHqSuperAdmin();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Canteen records ────────────────────────────────
    match /rehab_canteen/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('cashier'))
        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId);
      allow create, update: if isRehabRole('cashier') || isRehabSuperAdmin();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Rehab salary records ───────────────────────────
    // Superadmin/admin create and approve staff salary payment records.
    match /rehab_salary_records/{docId} {
      allow read: if isRehabAdminOrAbove();
      allow write: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Transactions ───────────────────────────────────
    // Cashier creates. Superadmin approves/rejects (update).
    // Admin can create pending requests (admin enters amount).
    // Superadmin approves/rejects (update). Cashier forwards requests (update).
    // Nobody deletes transactions — full audit trail.
    match /rehab_transactions/{docId} {
      allow read: if isRehabAdminOrAbove() || isRehabRole('cashier') || isHqSuperAdmin();
      allow create: if isRehabRole('cashier')
        || isRehabSuperAdmin()
        || (isRehabAdminOrAbove() && request.resource.data.status == 'pending_cashier');
      allow update: if isRehabSuperAdmin()
        || isHqSuperAdmin()
        || (
          isRehabRole('cashier')
          && resource.data.status == 'pending_cashier'
          && request.resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'proofUrl',
            'proofMissingReason',
            'proofRequired',
            'cashierForwardedAt',
            'cashierForwardedBy',
            'cashierForwardedByName'
          ])
        );
      allow delete: if false;
    }

    // ── Staff profiles ─────────────────────────────────
    // Staff can read their own profile only.
    // Admin/superadmin can read and write all.
    match /rehab_staff/{staffId} {
      allow read: if isRehabAdminOrAbove()
        || isRehabRole('cashier')
        || (isRehabRole('staff') && rehabStaffId() == staffId)
        || isHqSuperOrManager();
      allow create, update: if isRehabAdminOrAbove() || isHqSuperOrManager();
      allow delete: if isRehabSuperAdmin() || isHqSuperOrManager();
    }

    // ── Attendance ─────────────────────────────────────
    // Staff can create their own attendance (self check-in).
    // Admin can update (override). Nobody deletes.
    match /rehab_attendance/{docId} {
      allow read: if isRehabAdminOrAbove()
        || isRehabRole('cashier')
        || isRehabRole('staff')
        || isHqSuperOrManager();
      allow create: if isRehabRole('staff') || isRehabAdminOrAbove();
      allow update: if isRehabRole('staff') || isRehabAdminOrAbove();
      allow delete: if false;
    }

    // ── Departmental Staff Operational Rules (Rehab, SPIMS, etc.) ─────────────────

    // Patterns: {dept}_dress_code, {dept}_duty_log, {dept}_staff_dress_config, {dept}_staff_duty_config
    
    // REHAB
    match /rehab_dress_code/{docId} {
      allow read: if isHqSuperOrManager() || (isRehabAuth() && resource.data.staffId == request.auth.uid);
      allow write: if isHqSuperOrManager();
    }
    match /rehab_duty_log/{docId} {
      allow read: if isHqSuperOrManager() || (isRehabAuth() && resource.data.staffId == request.auth.uid);
      allow write: if isHqSuperOrManager();
    }
    match /rehab_staff_dress_config/{docId} {
      allow read: if isAuth(); // Any authenticated user can read config
      allow write: if isHqSuperOrManager();
    }
    match /rehab_staff_duty_config/{docId} {
      allow read: if isAuth();
      allow write: if isHqSuperOrManager();
    }

    // ── Patient videos ─────────────────────────────────
    // Family can read only their patient's videos.
    // Admin/superadmin can read and write all.
    match /rehab_videos/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Patient visits ─────────────────────────────────
    // Family can read only their patient's visits.
    // Admin/superadmin can read and write all.
    match /rehab_visits/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Audit log ──────────────────────────────────────
    // Only superadmin can read. 
    // Server actions write via Admin SDK (bypasses rules).
    // Client writes allowed for fire-and-forget audit entries
    // from authenticated rehab users only.
    match /rehab_audit/{docId} {
      allow read: if isRehabSuperAdmin() || isHqSuperOrManager();
      allow create: if isRehabAuth();
      allow update, delete: if false;
    }

    // ── Deletion logs (Audit trail for sensitive financial deletions) ──
    match /rehab_deletion_logs/{docId} {
      allow read: if isRehabSuperAdmin();
      allow create: if isRehabSuperAdmin();
      allow update, delete: if false;
    }

    // ── Staff contributions ────────────────────────────
    match /rehab_contributions/{docId} {
      allow read: if isRehabRole('admin')
        || isHqSuperOrManager()
        || isOwnStaffRecord(resource.data.staffId);
      allow create: if isRehabRole('staff') || isRehabRole('admin');
      allow update: if isRehabRole('admin') || isHqSuperOrManager()
        || (isOwnStaffRecord(resource.data.staffId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content']));
      allow delete: if false;
    }

    // ── Staff fines ────────────────────────────────────
    // Admin/superadmin read and write. Staff reads own fines.
    match /rehab_fines/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('staff') 
            && resource.data.staffId == request.auth.uid);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Staff leaves ───────────────────────────────────
    // Admin/superadmin read and write. Staff reads own leaves.
    match /rehab_leaves/{docId} {
      allow read: if isRehabAdminOrAbove()
        || (isRehabRole('staff') 
            && resource.data.staffId == request.auth.uid);
      allow create, update: if isRehabAdminOrAbove();
      allow delete: if isRehabSuperAdmin();
    }

    // ── Duty Logs ─────────────────────────────────────────────────────────────
    match /rehab_duty_logs/{docId} {
      allow read: if isRehabRole('admin')
        || isHqSuperOrManager()
        || isOwnStaffRecord(resource.data.staffId);
      allow create, update: if isRehabRole('admin') || isHqSuperOrManager();
      allow delete: if false;
    }

    // ── Dress Logs ────────────────────────────────────────────────────────────
    match /rehab_dress_logs/{docId} {
      allow read: if isRehabRole('admin')
        || isHqSuperOrManager()
        || isOwnStaffRecord(resource.data.staffId);
      allow create, update: if isRehabRole('admin') || isHqSuperOrManager();
      allow delete: if false;
    }

    // ── Growth Points ─────────────────────────────────────────────────────────
    match /rehab_growth_points/{docId} {
      allow read: if isRehabRole('admin')
        || isHqSuperOrManager()
        || isOwnStaffRecord(resource.data.staffId);
      allow create, update: if isRehabRole('admin') || isHqSuperOrManager();
      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════
    //  SPIMS COLLEGE PORTAL HELPERS
    // ═══════════════════════════════════════════════════════════

    function isSpimsAuth() {
      return request.auth != null
        && exists(/databases/$(database)/documents/spims_users/$(request.auth.uid));
    }
    function spimsRole() {
      return get(/databases/$(database)/documents/spims_users/$(request.auth.uid)).data.role;
    }
    function isSpimsRole(role) {
      return isSpimsAuth() && spimsRole() == role;
    }
    function isSpimsAdminOrAbove() {
      return isSpimsAuth()
        && (spimsRole() == 'admin' || spimsRole() == 'superadmin');
    }
    function isSpimsSuperAdmin() {
      return isSpimsRole('superadmin');
    }
    function spimsStudentId() {
      return get(/databases/$(database)/documents/spims_users/$(request.auth.uid)).data.studentId;
    }
    function spimsStaffId() {
      return get(/databases/$(database)/documents/spims_users/$(request.auth.uid)).data.staffId;
    }

    // ═══════════════════════════════════════════════════════════
    //  SPIMS COLLEGE PORTAL COLLECTIONS
    // ═══════════════════════════════════════════════════════════

    match /spims_meta/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /spims_users/{uid} {
      allow read: if (request.auth != null
        && (request.auth.uid == uid || isSpimsAdminOrAbove()))
        || isDiscoveryQuery()
        || isHqSuperOrManager();
      allow create: if isSpimsSuperAdmin() || isHqSuperOrManager();
      allow delete: if isSpimsSuperAdmin() || isHqSuperOrManager();
      allow update: if (request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['photoUrl', 'displayName', 'phone']))
        || isHqSuperOrManager();
    }

    match /spims_students/{studentId} {
      allow read: if isSpimsAdminOrAbove()
        || isSpimsRole('cashier')
        || (isSpimsRole('student') && spimsStudentId() == studentId);
      allow create, update: if isSpimsAdminOrAbove();
      allow delete: if isSpimsSuperAdmin();
    }

    match /spims_fees/{docId} {
      allow read: if isSpimsAdminOrAbove()
        || (isSpimsRole('cashier'))
        || (isSpimsRole('student') && spimsStudentId() == resource.data.studentId)
        || isHqSuperAdmin();
      allow create: if isSpimsAdminOrAbove() || isSpimsRole('cashier');
      allow update: if isSpimsAdminOrAbove() || isSpimsRole('cashier') || isSpimsSuperAdmin() || isHqSuperAdmin();
      allow delete: if isSpimsSuperAdmin();
    }

    match /spims_student_documents/{docId} {
      allow read: if isSpimsAdminOrAbove()
        || (isSpimsRole('student') && spimsStudentId() == resource.data.studentId);
      allow create, update, delete: if isSpimsAdminOrAbove();
    }

    // Student specific records (similar to patient records)
    match /spims_board_fees/{docId} {
      allow read: if isSpimsAdminOrAbove()
        || (isSpimsRole('cashier'))
        || (isSpimsRole('student') && spimsStudentId() == resource.data.studentId);
      allow write: if isSpimsRole('cashier') || isSpimsSuperAdmin();
    }

    match /spims_exams/{docId} {
      allow read: if isSpimsAdminOrAbove()
        || (isSpimsRole('student') && spimsStudentId() == resource.data.studentId);
      allow create, update: if isSpimsAdminOrAbove();
      allow delete: if isSpimsSuperAdmin();
    }

    match /spims_transactions/{docId} {
      allow read: if isSpimsAdminOrAbove() || isSpimsRole('cashier') || isHqSuperAdmin();
      allow create: if isSpimsRole('cashier') || isSpimsSuperAdmin();
      allow update: if isSpimsSuperAdmin() || isHqSuperAdmin();
      allow delete: if false;
    }

    match /spims_staff/{staffId} {
      allow read: if isSpimsAdminOrAbove()
        || isSpimsRole('cashier')
        || (isSpimsRole('staff') && spimsStaffId() == staffId)
        || isHqSuperOrManager();
      allow create, update: if isSpimsAdminOrAbove() || isHqSuperOrManager();
      allow delete: if isSpimsSuperAdmin() || isHqSuperOrManager();
    }

    match /spims_attendance/{docId} {
      allow read: if isSpimsAdminOrAbove()
        || isSpimsRole('cashier')
        || isSpimsRole('staff')
        || isHqSuperOrManager();
      allow create, update: if isSpimsRole('staff') || isSpimsAdminOrAbove() || isHqSuperOrManager();
      allow delete: if false;
    }

    // SPIMS
    match /spims_dress_code/{docId} {
      allow read: if isHqSuperOrManager() || (isSpimsAuth() && resource.data.staffId == request.auth.uid);
      allow write: if isHqSuperOrManager();
    }
    match /spims_duty_log/{docId} {
      allow read: if isHqSuperOrManager() || (isSpimsAuth() && resource.data.staffId == request.auth.uid);
      allow write: if isHqSuperOrManager();
    }
    match /spims_staff_dress_config/{docId} {
      allow read: if isAuth();
      allow write: if isHqSuperOrManager();
    }
    match /spims_staff_duty_config/{docId} {
      allow read: if isAuth();
      allow write: if isHqSuperOrManager();
    }

    // SPIMS operational logs (named with _logs suffix)
    match /spims_dress_logs/{logId} {
      allow read: if isSpimsAdminOrAbove() || isHqSuperOrManager();
      allow create, update: if isSpimsAdminOrAbove() || isHqSuperOrManager();
    }
    match /spims_duty_logs/{logId} {
      allow read: if isSpimsAdminOrAbove() || isHqSuperOrManager();
      allow create, update: if isSpimsAdminOrAbove() || isHqSuperOrManager();
    }

    // spims_tests — admin announcements for tests (course/session or single student)
    function spimsStudentDoc() {
      return get(/databases/$(database)/documents/spims_students/$(spimsStudentId())).data;
    }
    match /spims_tests/{docId} {
      allow read: if isSpimsAdminOrAbove()
        || (
          isSpimsRole('student')
          && (
            resource.data.scope == 'all'
            || (resource.data.scope == 'student' && resource.data.studentId == spimsStudentId())
            || (
              resource.data.scope == 'course_session'
              && resource.data.course == spimsStudentDoc().course
              && resource.data.session == spimsStudentDoc().session
            )
          )
        );
      allow create, update, delete: if isSpimsAdminOrAbove();
    }

    // spims_student_attendance — attendance marked by admin for students
    match /spims_student_attendance/{docId} {
      allow read: if isSpimsAdminOrAbove()
        || (isSpimsRole('student') && resource.data.studentId == spimsStudentId());
      allow create, update: if isSpimsAdminOrAbove();
      allow delete: if false;
    }

    match /spims_audit/{docId} {
      allow read: if isSpimsSuperAdmin() || isHqSuperOrManager();
      allow create: if isSpimsAuth();
      allow update, delete: if false;
    }

    match /spims_salary_records/{docId} {
      allow read: if isSpimsAdminOrAbove() || isSpimsRole('cashier');
      allow create: if isSpimsSuperAdmin();
      allow update: if isSpimsSuperAdmin();
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════ 
    //  HQ PORTAL HELPERS 
    //  Global system: superadmin, manager, cashier 
    //  Uses hq_users collection (doc ID = Firebase Auth uid) 
    // ═══════════════════════════════════════════════════════════ 

    function isHqAuth() { 
      return request.auth != null 
        && exists(/databases/$(database)/documents/hq_users/$(request.auth.uid)); 
    } 
    function hqRole() { 
      return get(/databases/$(database)/documents/hq_users/$(request.auth.uid)).data.role; 
    } 
    function hqCustomId() {
      return get(/databases/$(database)/documents/hq_users/$(request.auth.uid)).data.customId;
    }
    function isHqRole(role) { 
      return isHqAuth() && hqRole() == role; 
    } 
    function isHqSuperAdmin() { 
      return isHqRole('superadmin'); 
    } 
    function isHqCashier() { 
      return isHqRole('cashier'); 
    } 
    function isHqSuperOrManager() { 
      return isHqAuth() && (hqRole() == 'superadmin' || hqRole() == 'manager'); 
    } 
    function isHqTier1() { 
      return isHqAuth() && hqRole() in ['superadmin', 'manager', 'cashier']; 
    } 

    // ═══════════════════════════════════════════════════════════ 
    //  HQ PORTAL COLLECTIONS 
    // ═══════════════════════════════════════════════════════════ 

    // hq_meta — one-time setup flag 
    // Public read so setup page can check initialization status. 
    // Write: Firebase Admin SDK only (server action). 
    match /hq_meta/{docId} { 
      allow read: if true; 
      allow write: if false; 
    } 

    // hq_users — superadmin / manager / cashier profiles
    // Read: own doc OR any HQ tier1 user.
    // Create/Delete: server-side (Admin SDK) only.
    // Update:
    //  - superadmin/manager can update users (e.g. isActive)
    //  - owner can update limited profile fields only
    match /hq_users/{docId} {
      allow read: if (isHqAuth() && (request.auth.uid == docId || isHqTier1()))
        || isDiscoveryQuery();
      allow create, delete: if false;
      allow update: if isHqSuperOrManager()
        || (
          isHqAuth()
          && request.auth.uid == docId
          && request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasOnly(['photoUrl', 'name', 'phone'])
        );

      match /fcmTokens/{tokenId} {
        allow read, write: if isHqAuth() && request.auth.uid == docId;
      }
    }

    // hq_targets — monthly targets assigned to admin/staff 
    match /hq_targets/{docId} { 
      allow read: if isHqSuperOrManager() 
        || (request.auth != null && resource.data.staffId == request.auth.uid); 
      allow create: if isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
      allow delete: if isHqSuperAdmin(); 
    } 

    // hq_salary_records — staff salary payment records 
    match /hq_salary_records/{docId} { 
      allow read: if isHqTier1() 
        || (request.auth != null && resource.data.staffId == request.auth.uid); 
      allow create: if isHqTier1(); 
      allow update: if isHqTier1(); 
      allow delete: if isHqSuperAdmin(); 
    } 

    // hq_cashier_categories — reusable custom income/expense fields
    // Cashier/manager/superadmin can read and create.
    // Manager/superadmin can edit/delete for governance.
    match /hq_cashier_categories/{docId} {
      allow read: if isHqTier1();
      allow create: if isHqTier1();
      allow update, delete: if isHqSuperOrManager();
    }

    // hq_fines — late/discipline fines auto-created on attendance 
    match /hq_fines/{docId} { 
      allow read: if isHqSuperOrManager() 
        || (request.auth != null && resource.data.staffId == request.auth.uid); 
      allow create: if isHqSuperOrManager(); 
      allow update: if isHqSuperOrManager(); 
      allow delete: if isHqSuperAdmin(); 
    } 

    // hq_audit — cross-system audit log 
    match /hq_audit/{docId} { 
      allow read: if isHqSuperOrManager(); 
      allow create: if isHqAuth(); 
    } 

    // hq_settings — HQ superadmin settings (toggles/thresholds)
    match /hq_settings/{docId} {
      allow read: if isHqSuperAdmin();
      allow create, update: if isHqSuperAdmin();
      allow delete: if false;
    }

    // hq_notifications — in-app notifications for HQ users
    match /hq_notifications/{docId} {
      allow read: if isHqAuth()
        && resource.data.recipientId == get(/databases/$(database)/documents/hq_users/$(request.auth.uid)).data.customId;
      allow create: if isHqAuth();
      allow update: if isHqAuth()
        && resource.data.recipientId == get(/databases/$(database)/documents/hq_users/$(request.auth.uid)).data.customId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if false;
    }

    // hq_ledger_entries — immutable canonical ledger
    // Written by server action (Admin SDK) on every superadmin approval.
    // HQ tier1 can read. Nobody deletes or updates from client.
    match /hq_ledger_entries/{docId} {
      allow read: if isHqTier1();
      allow create: if isHqSuperAdmin();
      allow update, delete: if false;
    }

    // hq_reconciliation — daily cashier close records
    // Cashier creates. Superadmin/manager reads and verifies.
    // Nobody edits or deletes.
    match /hq_reconciliation/{docId} {
      allow read: if isHqSuperOrManager()
        || (isHqCashier() && resource.data.cashierId == hqCustomId());
      allow create: if isHqCashier() || isHqSuperOrManager();
      allow update: if isHqSuperOrManager();
      allow delete: if false;
    }

    // hq_growth_points — points system for HQ staff
    match /hq_growth_points/{docId} { 
      allow read: if isHqSuperOrManager() 
        || (request.auth != null && resource.data.staffId == request.auth.uid); 
      allow create, update: if isHqSuperOrManager(); 
      allow delete: if isHqSuperAdmin(); 
    } 

    // cashierTransactions — standardized global transaction log
    match /cashierTransactions/{docId} {
      allow read: if isHqTier1();
      allow create: if isHqCashier() || isHqSuperOrManager();
      allow update: if isHqSuperOrManager();
      allow delete: if false;
    }

    // hq_fees — global fee records (direct HQ collections)
    match /hq_fees/{docId} {
      allow read: if isHqSuperOrManager() || isHqCashier();
      allow create, update: if isHqCashier() || isHqSuperAdmin();
      allow delete: if isHqSuperAdmin();
    }

    // hq_staff — global staff profiles across all departments 
    // Read: any HQ tier1 OR rehab/spims admin 
    // Write: superadmin or manager only 
    match /hq_staff/{staffId} { 
      allow read: if isHqSuperOrManager(); 
      allow create, update, delete: if isHqSuperOrManager(); 
    } 

    // hq_attendance — staff attendance records (marked by manager only) 
    match /hq_attendance/{docId} { 
      allow read, create, update, delete: if isHqSuperOrManager(); 
    } 

    // ── Future departments staff-management (manager/superadmin only) ────────
    // Any new department that follows naming:
    //   {dept}_staff, {dept}_attendance, {dept}_duty_logs
    // is automatically manageable from HQ by manager/superadmin/cashier.
    match /{collectionId}/{docId} {
      allow read: if (isHqTier1()
        && (
          collectionId.matches('^[a-z0-9_-]+_staff$')
          || collectionId.matches('^[a-z0-9_-]+_attendance$')
          || collectionId.matches('^[a-z0-9_-]+_duty_logs$')
          || collectionId.matches('^[a-z0-9_-]+_duty_log$')
          || collectionId.matches('^[a-z0-9_-]+_dress_logs$')
          || collectionId.matches('^[a-z0-9_-]+_dress_code$')
          || collectionId.matches('^[a-z0-9_-]+_fines$')
          || collectionId.matches('^[a-z0-9_-]+_growth_points$')
          || collectionId.matches('^[a-z0-9_-]+_users$')
          || collectionId.matches('^[a-z0-9_-]+_debtors$')
          || collectionId.matches('^[a-z0-9_-]+_audit$')
          || collectionId.matches('^[a-z0-9_-]+_contributions$')
          || collectionId.matches('^[a-z0-9_-]+_salary_records$')
          || collectionId.matches('^[a-z0-9_-]+_special_tasks$')
          || collectionId.matches('^[a-z0-9_-]+_meta$')
        )) || (isDiscoveryQuery() && collectionId.matches('^[a-z0-9_-]+_users$'));
      allow create, update: if (isHqSuperOrManager() || (isHqCashier() && collectionId.matches('^[a-z0-9_-]+_salary_records$')))
        && (
          collectionId.matches('^[a-z0-9_-]+_staff$')
          || collectionId.matches('^[a-z0-9_-]+_attendance$')
          || collectionId.matches('^[a-z0-9_-]+_duty_logs$')
          || collectionId.matches('^[a-z0-9_-]+_duty_log$')
          || collectionId.matches('^[a-z0-9_-]+_dress_logs$')
          || collectionId.matches('^[a-z0-9_-]+_dress_code$')
          || collectionId.matches('^[a-z0-9_-]+_fines$')
          || collectionId.matches('^[a-z0-9_-]+_growth_points$')
          || collectionId.matches('^[a-z0-9_-]+_users$')
          || collectionId.matches('^[a-z0-9_-]+_debtors$')
          || collectionId.matches('^[a-z0-9_-]+_audit$')
          || collectionId.matches('^[a-z0-9_-]+_contributions$')
          || collectionId.matches('^[a-z0-9_-]+_salary_records$')
          || collectionId.matches('^[a-z0-9_-]+_special_tasks$')
          || collectionId.matches('^[a-z0-9_-]+_meta$')
        );
      allow delete: if isHqSuperOrManager()
        && (
          collectionId.matches('^[a-z0-9_-]+_staff$')
          || collectionId.matches('^[a-z0-9_-]+_users$')
          || collectionId.matches('^[a-z0-9_-]+_fines$')
          || collectionId.matches('^[a-z0-9_-]+_special_tasks$')
          || collectionId.matches('^[a-z0-9_-]+_meta$')
        );
    }

    // ═══════════════════════════════════════════════════════════
    //  HOSPITAL PORTAL HELPERS
    // ═══════════════════════════════════════════════════════════

    function isHospitalAuth() {
      return request.auth != null
        && exists(/databases/$(database)/documents/hospital_users/$(request.auth.uid));
    }
    function hospitalRole() {
      return get(/databases/$(database)/documents/hospital_users/$(request.auth.uid)).data.role;
    }
    function isHospitalRole(role) {
      return isHospitalAuth() && hospitalRole() == role;
    }
    function isHospitalAdminOrAbove() {
      return isHospitalAuth()
        && (hospitalRole() == 'admin' || hospitalRole() == 'superadmin');
    }
    function isHospitalSuperAdmin() {
      return isHospitalRole('superadmin');
    }
    function hospitalPatientId() {
      return get(/databases/$(database)/documents/hospital_users/$(request.auth.uid)).data.patientId;
    }
    function hospitalStaffId() {
      return get(/databases/$(database)/documents/hospital_users/$(request.auth.uid)).data.staffId;
    }

    // ═══════════════════════════════════════════════════════════
    //  HOSPITAL PORTAL COLLECTIONS
    // ═══════════════════════════════════════════════════════════

    match /hospital_meta/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /hospital_users/{uid} {
      allow read: if (request.auth != null
        && (request.auth.uid == uid || isHospitalAdminOrAbove()))
        || isHqSuperOrManager();
      allow create: if isHospitalSuperAdmin() || isHqSuperOrManager();
      allow delete: if isHospitalSuperAdmin() || isHqSuperOrManager();
      allow update: if (request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['photoUrl', 'displayName', 'phone']))
        || isHqSuperOrManager();
    }

    match /hospital_patients/{patientId} {
      allow read: if isHospitalAdminOrAbove()
        || isHospitalRole('cashier')
        || (isHospitalRole('patient') && hospitalPatientId() == patientId);
      allow create, update: if isHospitalAdminOrAbove() || isHqSuperOrManager();
      allow delete: if isHospitalSuperAdmin();
    }

    match /hospital_fees/{docId} {
      allow read: if isHospitalAdminOrAbove()
        || (isHospitalRole('cashier'))
        || (isHospitalRole('patient') && hospitalPatientId() == resource.data.patientId);
      allow write: if isHospitalRole('cashier') || isHospitalSuperAdmin();
    }

    match /hospital_transactions/{docId} {
      allow read: if isHospitalAdminOrAbove() || isHospitalRole('cashier');
      allow create: if isHospitalRole('cashier')
        || isHospitalSuperAdmin()
        || (isHospitalAdminOrAbove() && request.resource.data.status == 'pending_cashier');
      allow update: if isHospitalSuperAdmin()
        || (
          isHospitalRole('cashier')
          && resource.data.status == 'pending_cashier'
          && request.resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'proofUrl',
            'proofMissingReason',
            'proofRequired',
            'cashierForwardedAt',
            'cashierForwardedBy',
            'cashierForwardedByName'
          ])
        );
      allow delete: if false;
    }

    match /hospital_staff/{staffId} {
      allow read: if isHospitalAdminOrAbove()
        || isHospitalRole('cashier')
        || (isHospitalRole('staff') && hospitalStaffId() == staffId)
        || isHqSuperOrManager();
      allow create, update: if isHospitalAdminOrAbove() || isHqSuperOrManager();
      allow delete: if isHospitalSuperAdmin() || isHqSuperOrManager();
    }

    match /hospital_attendance/{docId} {
      allow read: if isHospitalAdminOrAbove()
        || isHospitalRole('cashier')
        || isHospitalRole('staff')
        || isHqSuperOrManager();
      allow create, update: if isHospitalRole('staff') || isHospitalAdminOrAbove() || isHqSuperOrManager();
      allow delete: if false;
    }

    match /hospital_dress_logs/{logId} {
      allow read: if isHospitalAdminOrAbove() || isHqSuperOrManager();
      allow create, update: if isHospitalAdminOrAbove() || isHqSuperOrManager();
    }

    match /hospital_duty_logs/{logId} {
      allow read: if isHospitalAdminOrAbove() || isHqSuperOrManager();
      allow create, update: if isHospitalAdminOrAbove() || isHqSuperOrManager();
    }

    match /hospital_audit/{docId} {
      allow read: if isHospitalSuperAdmin() || isHqSuperOrManager();
      allow create: if isHospitalAuth();
      allow update, delete: if false;
    }

    match /hospital_salary_records/{docId} {
      allow read: if isHospitalAdminOrAbove();
      allow write: if isHospitalAdminOrAbove();
      allow delete: if isHospitalSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    //  SUKOON PORTAL HELPERS
    // ═══════════════════════════════════════════════════════════

    function isSukoonAuth() {
      return request.auth != null
        && exists(/databases/$(database)/documents/sukoon_users/$(request.auth.uid));
    }
    function sukoonRole() {
      return get(/databases/$(database)/documents/sukoon_users/$(request.auth.uid)).data.role;
    }
    function isSukoonRole(role) {
      return isSukoonAuth() && sukoonRole() == role;
    }
    function isSukoonAdminOrAbove() {
      return isSukoonAuth()
        && (sukoonRole() == 'admin' || sukoonRole() == 'superadmin');
    }
    function isSukoonSuperAdmin() {
      return isSukoonRole('superadmin');
    }
    function sukoonClientId() {
      return get(/databases/$(database)/documents/sukoon_users/$(request.auth.uid)).data.clientId;
    }
    function sukoonStaffId() {
      return get(/databases/$(database)/documents/sukoon_users/$(request.auth.uid)).data.staffId;
    }

    // ═══════════════════════════════════════════════════════════
    //  SUKOON PORTAL COLLECTIONS
    // ═══════════════════════════════════════════════════════════

    match /sukoon_meta/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /sukoon_users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isSukoonAdminOrAbove());
      allow create: if isSukoonSuperAdmin() || isHqSuperOrManager();
      allow delete: if isSukoonSuperAdmin() || isHqSuperOrManager();
      allow update: if (request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['photoUrl', 'displayName', 'phone']))
        || isHqSuperOrManager();
    }

    match /sukoon_clients/{clientId} {
      allow read: if isSukoonAdminOrAbove()
        || isSukoonRole('cashier')
        || (isSukoonRole('client') && sukoonClientId() == clientId);
      allow create, update: if isSukoonAdminOrAbove() || isHqSuperOrManager();
      allow delete: if isSukoonSuperAdmin();
    }

    match /sukoon_fees/{docId} {
      allow read: if isSukoonAdminOrAbove()
        || (isSukoonRole('cashier'))
        || (isSukoonRole('client') && sukoonClientId() == resource.data.clientId);
      allow write: if isSukoonRole('cashier') || isSukoonSuperAdmin();
    }

    match /sukoon_transactions/{docId} {
      allow read: if isSukoonAdminOrAbove() || isSukoonRole('cashier');
      allow create: if isSukoonRole('cashier')
        || isSukoonSuperAdmin()
        || (isSukoonAdminOrAbove() && request.resource.data.status == 'pending_cashier');
      allow update: if isSukoonSuperAdmin()
        || (
          isSukoonRole('cashier')
          && resource.data.status == 'pending_cashier'
          && request.resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'proofUrl',
            'proofMissingReason',
            'proofRequired',
            'cashierForwardedAt',
            'cashierForwardedBy',
            'cashierForwardedByName'
          ])
        );
      allow delete: if false;
    }

    match /sukoon_staff/{staffId} {
      allow read: if isSukoonAdminOrAbove()
        || isSukoonRole('cashier')
        || (isSukoonRole('staff') && sukoonStaffId() == staffId)
        || isHqSuperOrManager();
      allow create, update: if isSukoonAdminOrAbove() || isHqSuperOrManager();
      allow delete: if isSukoonSuperAdmin() || isHqSuperOrManager();
    }

    match /sukoon_attendance/{docId} {
      allow read: if isSukoonAdminOrAbove()
        || isSukoonRole('cashier')
        || isSukoonRole('staff')
        || isHqSuperOrManager();
      allow create, update: if isSukoonRole('staff') || isSukoonAdminOrAbove() || isHqSuperOrManager();
      allow delete: if false;
    }

    match /sukoon_dress_logs/{logId} {
      allow read: if isSukoonAdminOrAbove() || isHqSuperOrManager();
      allow create, update: if isSukoonAdminOrAbove() || isHqSuperOrManager();
    }

    match /sukoon_duty_logs/{logId} {
      allow read: if isSukoonAdminOrAbove() || isHqSuperOrManager();
      allow create, update: if isSukoonAdminOrAbove() || isHqSuperOrManager();
    }

    match /sukoon_audit/{docId} {
      allow read: if isSukoonSuperAdmin() || isHqSuperOrManager();
      allow create: if isSukoonAuth();
      allow update, delete: if false;
    }

    match /sukoon_salary_records/{docId} {
      allow read: if isSukoonAdminOrAbove();
      allow write: if isSukoonAdminOrAbove();
      allow delete: if isSukoonSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    //  WELFARE PORTAL HELPERS
    // ═══════════════════════════════════════════════════════════

    function isWelfareAuth() {
      return request.auth != null
        && exists(/databases/$(database)/documents/welfare_users/$(request.auth.uid));
    }
    function welfareRole() {
      return get(/databases/$(database)/documents/welfare_users/$(request.auth.uid)).data.role;
    }
    function isWelfareRole(role) {
      return isWelfareAuth() && welfareRole() == role;
    }
    function isWelfareAdminOrAbove() {
      return isWelfareAuth()
        && (welfareRole() == 'admin' || welfareRole() == 'superadmin');
    }
    function isWelfareSuperAdmin() {
      return isWelfareRole('superadmin');
    }
    function welfareChildId() {
      return get(/databases/$(database)/documents/welfare_users/$(request.auth.uid)).data.childId;
    }
    function welfareStaffId() {
      return get(/databases/$(database)/documents/welfare_users/$(request.auth.uid)).data.staffId;
    }

    // ═══════════════════════════════════════════════════════════
    //  WELFARE PORTAL COLLECTIONS
    // ═══════════════════════════════════════════════════════════

    match /welfare_meta/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /welfare_users/{uid} {
      allow read: if (request.auth != null
        && (request.auth.uid == uid || isWelfareAdminOrAbove()))
        || isHqSuperOrManager();
      allow create: if isWelfareSuperAdmin() || isHqSuperOrManager();
      allow delete: if isWelfareSuperAdmin() || isHqSuperOrManager();
      allow update: if (request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['photoUrl', 'displayName', 'phone']))
        || isHqSuperOrManager();
    }

    match /welfare_children/{childId} {
      allow read: if isWelfareAdminOrAbove()
        || isWelfareRole('cashier')
        || (isWelfareRole('child') && welfareChildId() == childId);
      allow create, update: if isWelfareAdminOrAbove();
      allow delete: if isWelfareSuperAdmin();
    }

    match /welfare_fees/{docId} {
      allow read: if isWelfareAdminOrAbove()
        || (isWelfareRole('cashier'))
        || (isWelfareRole('child') && welfareChildId() == resource.data.childId);
      allow write: if isWelfareRole('cashier') || isWelfareSuperAdmin();
    }

    match /welfare_transactions/{docId} {
      allow read: if isWelfareAdminOrAbove() || isWelfareRole('cashier');
      allow create: if isWelfareRole('cashier')
        || isWelfareSuperAdmin()
        || (isWelfareAdminOrAbove() && request.resource.data.status == 'pending_cashier');
      allow update: if isWelfareSuperAdmin()
        || (
          isWelfareRole('cashier')
          && resource.data.status == 'pending_cashier'
          && request.resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'proofUrl',
            'proofMissingReason',
            'proofRequired',
            'cashierForwardedAt',
            'cashierForwardedBy',
            'cashierForwardedByName'
          ])
        );
      allow delete: if false;
    }

    match /welfare_staff/{staffId} {
      allow read: if isWelfareAdminOrAbove()
        || isWelfareRole('cashier')
        || (isWelfareRole('staff') && welfareStaffId() == staffId)
        || isHqSuperOrManager();
      allow create, update: if isWelfareAdminOrAbove() || isHqSuperOrManager();
      allow delete: if isWelfareSuperAdmin() || isHqSuperOrManager();
    }

    match /welfare_attendance/{docId} {
      allow read: if isWelfareAdminOrAbove()
        || isWelfareRole('cashier')
        || isWelfareRole('staff')
        || isHqSuperOrManager();
      allow create, update: if isWelfareRole('staff') || isWelfareAdminOrAbove() || isHqSuperOrManager();
      allow delete: if false;
    }

    match /welfare_dress_logs/{logId} {
      allow read: if isWelfareAdminOrAbove() || isHqSuperOrManager();
      allow create, update: if isWelfareAdminOrAbove() || isHqSuperOrManager();
    }

    match /welfare_duty_logs/{logId} {
      allow read: if isWelfareAdminOrAbove() || isHqSuperOrManager();
      allow create, update: if isWelfareAdminOrAbove() || isHqSuperOrManager();
    }

    match /welfare_audit/{docId} {
      allow read: if isWelfareSuperAdmin() || isHqSuperOrManager();
      allow create: if isWelfareAuth();
      allow update, delete: if false;
    }

    match /welfare_salary_records/{docId} {
      allow read: if isWelfareAdminOrAbove();
      allow write: if isWelfareAdminOrAbove();
      allow delete: if isWelfareSuperAdmin();
    }

    match /welfare_canteen/{docId} {
      allow read: if isWelfareAdminOrAbove()
        || isWelfareRole('cashier')
        || (isWelfareRole('child') && welfareChildId() == resource.data.childId);
      allow create, update: if isWelfareRole('cashier') || isWelfareAdminOrAbove();
      allow delete: if isWelfareSuperAdmin();
    }

    match /welfare_videos/{docId} {
      allow read: if isWelfareAdminOrAbove()
        || (isWelfareRole('child') && welfareChildId() == resource.data.patientId);
      allow create: if isWelfareAdminOrAbove();
      allow delete: if isWelfareAdminOrAbove();
    }

    match /welfare_visits/{docId} {
      allow read: if isWelfareAdminOrAbove()
        || (isWelfareRole('child') && welfareChildId() == resource.data.patientId);
      allow create, update: if isWelfareAdminOrAbove();
      allow delete: if isWelfareSuperAdmin();
    }

    match /welfare_fines/{docId} {
      allow read: if isWelfareAdminOrAbove()
