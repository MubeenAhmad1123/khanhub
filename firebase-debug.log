rite: if isHqSuperOrManager();\r\n    }\r\n\r\n    match /welfare_dress_code/{docId} {\r\n      allow read: if isHqSuperOrManager() || (isWelfareAuth() && resource.data.staffId == request.auth.uid);\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n    match /welfare_duty_log/{docId} {\r\n      allow read: if isHqSuperOrManager() || (isWelfareAuth() && resource.data.staffId == request.auth.uid);\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n    match /welfare_staff_dress_config/{docId} {\r\n      allow read: if isAuth();\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n    match /welfare_staff_duty_config/{docId} {\r\n      allow read: if isAuth();\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n\r\n    match /job_center_dress_code/{docId} {\r\n      allow read: if isHqSuperOrManager() || (isJobCenterAuth() && resource.data.staffId == request.auth.uid);\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n    match /job_center_duty_log/{docId} {\r\n      allow read: if isHqSuperOrManager() || (isJobCenterAuth() && resource.data.staffId == request.auth.uid);\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n    match /job_center_staff_dress_config/{docId} {\r\n      allow read: if isAuth();\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n    match /job_center_staff_duty_config/{docId} {\r\n      allow read: if isAuth();\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  JOB CENTER PORTAL COLLECTIONS (NEW)\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    function jobCenterUserDoc() {\r\n      return get(/databases/$(database)/documents/jobcenter_users/$(request.auth.uid)).data;\r\n    }\r\n    \r\n    function isJobCenterAdmin() {\r\n      return isJobCenterAuth() && (jobCenterUserDoc().role == 'admin' || jobCenterUserDoc().role == 'superadmin');\r\n    }\r\n    \r\n    function isJobCenterStaff() {\r\n      return isJobCenterAuth() && (jobCenterUserDoc().role == 'staff' || isJobCenterAdmin());\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  JOB CENTER PORTAL COLLECTIONS\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    match /jobcenter_users/{uid} {\r\n      allow read: if isJobCenterAuth() && (request.auth.uid == uid || isJobCenterAdmin());\r\n      allow write: if isJobCenterAdmin();\r\n    }\r\n\r\n    match /jobcenter_seekers/{seekerId} {\r\n      allow read: if isJobCenterAuth();\r\n      allow create, update: if isJobCenterAdmin();\r\n      allow delete: if isJobCenterAdmin();\r\n    }\r\n\r\n    match /jobcenter_employers/{employerId} {\r\n      allow read: if isJobCenterAuth();\r\n      allow create, update: if isJobCenterAdmin();\r\n      allow delete: if isJobCenterAdmin();\r\n    }\r\n\r\n    match /jobcenter_jobs/{jobId} {\r\n      allow read: if true; // Public or seeker access\r\n      allow create, update: if isJobCenterAdmin() || (isJobCenterAuth() && jobCenterUserDoc().role == 'employer');\r\n      allow delete: if isJobCenterAdmin();\r\n    }\r\n\r\n    match /jobcenter_transactions/{docId} {\r\n      allow read: if isJobCenterAuth();\r\n      allow create: if isJobCenterStaff();\r\n      allow update: if isJobCenterAdmin();\r\n    }\r\n\r\n    match /jobcenter_attendance/{docId} {\r\n      allow read: if isJobCenterAuth();\r\n      allow write: if isJobCenterStaff();\r\n    }\r\n\r\n    match /jobcenter_daily_activities/{docId} {\r\n      allow read: if isJobCenterAuth();\r\n      allow write: if isJobCenterStaff();\r\n    }\r\n\r\n    match /jobcenter_contributions/{docId} {\r\n      allow read: if isJobCenterAuth();\r\n      allow create: if isJobCenterStaff();\r\n      allow update, delete: if isJobCenterAdmin();\r\n    }\r\n\r\n    match /jobcenter_audit/{docId} {\r\n      allow read: if isJobCenterAdmin();\r\n      allow create: if isJobCent