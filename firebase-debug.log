[debug] [2026-04-19T13:41:31.308Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/khanhub-5e552/rulesets {"name":"projects/khanhub-5e552/rulesets/0f223586-a2b7-4832-b227-7640bb5242d1","source":{"files":[{"content":"rules_version = '2';\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  SHARED HELPERS  (job platform — do not modify)\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    function isAuth() {\r\n      return request.auth != null;\r\n    }\r\n    function isDiscoveryQuery() {\r\n      return request.query.limit != null && request.query.limit <= 1;\r\n    }\r\n    function isOwner(uid) {\r\n      return isAuth() && request.auth.uid == uid;\r\n    }\r\n    function isAdmin() {\r\n      return isAuth() &&\r\n        get(/databases/$(database)/documents/users/$(request.auth.uid))\r\n          .data.get('role', '') == 'admin';\r\n    }\r\n    function isCashier() {\r\n      return isAuth() &&\r\n        get(/databases/$(database)/documents/users/$(request.auth.uid))\r\n          .data.get('role', '') == 'cashier';\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  JOB PLATFORM COLLECTIONS  (unchanged — do not modify)\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    // ── Users ─────────────────────────────────────────\r\n    match /users/{uid} {\r\n      allow read: if true;\r\n      allow create: if isOwner(uid);\r\n      allow update: if isOwner(uid)\r\n        || isAdmin()\r\n        || (isAuth() && request.resource.data.diff(resource.data)\r\n            .affectedKeys().hasOnly([\r\n              'followerCount', 'followingCount',\r\n              'likedVideos', 'savedVideos',\r\n              'interestedVideos', 'notInterestedVideos',\r\n              'totalLikes', 'watchedVideos'\r\n            ]));\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ── Videos ───────────────────────────────────────\r\n    match /videos/{videoId} {\r\n      allow read: if true;\r\n      allow create: if isAuth()\r\n        && request.resource.data.userId == request.auth.uid;\r\n      allow update: if isAdmin()\r\n        || (isAuth() && resource.data.userId == request.auth.uid)\r\n        || (isAuth() && request.resource.data.diff(resource.data)\r\n            .affectedKeys().hasOnly(['views', 'likes', 'likedBy']));\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ── Follows ───────────────────────────────────────\r\n    match /follows/{followId} {\r\n      allow read: if true;\r\n      allow create: if isAuth()\r\n        && request.resource.data.followerId == request.auth.uid;\r\n      allow delete: if isAuth()\r\n        && resource.data.followerId == request.auth.uid;\r\n    }\r\n\r\n    // ── Notifications ─────────────────────────────────\r\n    match /notifications/{notifId} {\r\n      allow read: if isAuth()\r\n        && (resource.data.userId == request.auth.uid || isAdmin());\r\n      allow create: if isAuth();\r\n      allow update: if isAuth()\r\n        && (resource.data.userId == request.auth.uid || isAdmin());\r\n      allow delete: if isAuth()\r\n        && (resource.data.userId == request.auth.uid || isAdmin());\r\n    }\r\n\r\n    // ── Payments ──────────────────────────────────────\r\n    match /payments/{payId} {\r\n      allow read: if isAuth()\r\n        && (resource.data.userId == request.auth.uid || isAdmin());\r\n      allow create: if isAuth();\r\n      allow update: if isAdmin();\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ── Payment Requests ──────────────────────────────\r\n    match /paymentRequests/{reqId} {\r\n      allow read: if isAuth()\r\n        && (resource.data.requestedBy == request.auth.uid || isAdmin() || isCashier());\r\n      allow create: if isAuth()\r\n        && request.resource.data.requestedBy == request.auth.uid;\r\n      allow update: if isAdmin() || isCashier();\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ── Video Payments ────────────────────────────────\r\n    match /videoPayments/{reqId} {\r\n      allow read: if isAuth()\r\n        && (resource.data.requestedBy == request.auth.uid || isAdmin());\r\n      allow create: if isAuth()\r\n        && request.resource.data.requestedBy == request.auth.uid;\r\n      allow update: if isAdmin();\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ── Jobs ──────────────────────────────────────────\r\n    match /jobs/{jobId} {\r\n      allow read: if true;\r\n      allow create: if isAuth();\r\n      allow update: if isAuth()\r\n        && (resource.data.employerId == request.auth.uid || isAdmin());\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ── Applications ──────────────────────────────────\r\n    match /applications/{appId} {\r\n      allow read: if isAuth()\r\n        && (resource.data.applicantId == request.auth.uid\r\n            || resource.data.employerId == request.auth.uid\r\n            || isAdmin());\r\n      allow create: if isAuth();\r\n      allow update: if isAdmin();\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ── Connections ───────────────────────────────────\r\n    match /connections/{conId} {\r\n      allow read: if isAuth()\r\n        && (resource.data.seekerId == request.auth.uid\r\n            || resource.data.employerId == request.auth.uid\r\n            || isAdmin());\r\n      allow create: if isAuth();\r\n      allow update: if isAuth()\r\n        && (resource.data.seekerId == request.auth.uid\r\n            || resource.data.employerId == request.auth.uid\r\n            || isAdmin());\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ── Admin Settings ────────────────────────────────\r\n    match /adminSettings/{doc} {\r\n      allow read, write: if isAdmin();\r\n    }\r\n\r\n    // ── Likes (Fallback rule) ─────────────────────────\r\n    match /likes/{likeId} {\r\n      allow read: if true;\r\n      allow write: if isAuth();\r\n    }\r\n\r\n    // ── Video Feedback ────────────────────────────────\r\n    match /video_feedback/{feedbackId} {\r\n      allow read: if isAdmin();\r\n      allow create: if isAuth()\r\n        && request.resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // ── Reports ───────────────────────────────────────\r\n    match /reports/{reportId} {\r\n      allow read: if isAdmin();\r\n      allow create: if isAuth()\r\n        && request.resource.data.reportedBy == request.auth.uid;\r\n    }\r\n\r\n    // ── Interests ─────────────────────────────────────\r\n    match /interests/{interestId} {\r\n      allow read: if isAdmin()\r\n        || (isAuth() && resource.data.userId == request.auth.uid);\r\n      allow create: if isAuth()\r\n        && request.resource.data.userId == request.auth.uid;\r\n      allow delete: if isAuth()\r\n        && resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  REHAB PORTAL HELPERS\r\n    //  Separate from job platform — uses rehab_users collection\r\n    //  The isAdmin() above checks /users/ — these check /rehab_users/\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    function isRehabAuth() {\r\n      return request.auth != null\r\n        && exists(/databases/$(database)/documents/rehab_users/$(request.auth.uid));\r\n    }\r\n    function rehabRole() {\r\n      return get(/databases/$(database)/documents/rehab_users/$(request.auth.uid)).data.role;\r\n    }\r\n    function isRehabRole(role) {\r\n      return isRehabAuth() && rehabRole() == role;\r\n    }\r\n    function isRehabAdminOrAbove() {\r\n      return isRehabAuth()\r\n        && (rehabRole() == 'admin' || rehabRole() == 'superadmin');\r\n    }\r\n    function isRehabSuperAdmin() {\r\n      return isRehabRole('superadmin');\r\n    }\r\n    function rehabPatientId() {\r\n      return get(/databases/$(database)/documents/rehab_users/$(request.auth.uid)).data.patientId;\r\n    }\r\n    function rehabStaffId() {\r\n      return get(/databases/$(database)/documents/rehab_users/$(request.auth.uid)).data.staffId;\r\n    }\r\n    function isOwnStaffRecord(staffId) {\r\n      return isRehabRole('staff')\r\n        && (staffId == request.auth.uid || staffId == rehabStaffId());\r\n    }\r\n\r\n\r\n    // ── Rehab portal helpes ───────────────\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  REHAB PORTAL COLLECTIONS\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    // ── Setup meta (one-time init flag) ───────────────\r\n    // Public read so setup page can check if system is initialized.\r\n    // Write is false from client — only server action (Firebase Admin) writes this.\r\n    match /rehab_meta/{doc} {\r\n      allow read: if true;\r\n      allow write: if false;\r\n    }\r\n\r\n    // ── Rehab user profiles ────────────────────────────\r\n    // Users can read their own profile.\r\n    // Admin/superadmin can read all.\r\n    // Write is false from client — only server action (Firebase Admin) creates/updates.\r\n    match /rehab_users/{uid} {\r\n      allow read: if (request.auth != null\r\n        && (request.auth.uid == uid || isRehabAdminOrAbove()))\r\n        || isDiscoveryQuery()\r\n        || isHqSuperOrManager();\r\n      allow create: if isRehabSuperAdmin() || isHqSuperOrManager();\r\n      allow delete: if isRehabSuperAdmin() || isHqSuperOrManager();\r\n      allow update: if (request.auth != null\r\n        && request.auth.uid == uid\r\n        && request.resource.data.diff(resource.data)\r\n            .affectedKeys()\r\n            .hasOnly(['photoUrl', 'displayName', 'phone']))\r\n        || isHqSuperOrManager();\r\n    }\r\n\r\n    // ── Patients ───────────────────────────────────────\r\n    // Family can only read their linked patient.\r\n    // Admin/superadmin can read and write all.\r\n    // Delete only by superadmin.\r\n    match /rehab_patients/{patientId} {\r\n      allow read: if isRehabAdminOrAbove()\r\n        || isRehabRole('cashier')\r\n        || (isRehabRole('family') && rehabPatientId() == patientId);\r\n      allow create, update: if isRehabAdminOrAbove();\r\n      allow delete: if isRehabSuperAdmin();\r\n    }\r\n\r\n    // ── Fee records ────────────────────────────────────\r\n    // Family can read only their patient's fee record.\r\n    // Cashier and superadmin can write.\r\n    // Admin can read all (for reports).\r\n    match /rehab_fees/{docId} {\r\n      allow read: if isRehabAdminOrAbove()\r\n        || (isRehabRole('cashier'))\r\n        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId)\r\n        || isHqSuperAdmin();\r\n      allow create, update: if isRehabRole('cashier') || isRehabSuperAdmin() || isHqSuperAdmin();\r\n      allow delete: if isRehabSuperAdmin();\r\n    }\r\n\r\n    // ── Canteen records ────────────────────────────────\r\n    match /rehab_canteen/{docId} {\r\n      allow read: if isRehabAdminOrAbove()\r\n        || (isRehabRole('cashier'))\r\n        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId);\r\n      allow create, update: if isRehabRole('cashier') || isRehabSuperAdmin();\r\n      allow delete: if isRehabSuperAdmin();\r\n    }\r\n\r\n    // ── Rehab salary records ───────────────────────────\r\n    // Superadmin/admin create and approve staff salary payment records.\r\n    match /rehab_salary_records/{docId} {\r\n      allow read: if isRehabAdminOrAbove();\r\n      allow write: if isRehabAdminOrAbove();\r\n      allow delete: if isRehabSuperAdmin();\r\n    }\r\n\r\n    // ── Transactions ───────────────────────────────────\r\n    // Cashier creates. Superadmin approves/rejects (update).\r\n    // Admin can create pending requests (admin enters amount).\r\n    // Superadmin approves/rejects (update). Cashier forwards requests (update).\r\n    // Nobody deletes transactions — full audit trail.\r\n    match /rehab_transactions/{docId} {\r\n      allow read: if isRehabAdminOrAbove() || isRehabRole('cashier') || isHqSuperAdmin();\r\n      allow create: if isRehabRole('cashier')\r\n        || isRehabSuperAdmin()\r\n        || (isRehabAdminOrAbove() && request.resource.data.status == 'pending_cashier');\r\n      allow update: if isRehabSuperAdmin()\r\n        || isHqSuperAdmin()\r\n        || (\r\n          isRehabRole('cashier')\r\n          && resource.data.status == 'pending_cashier'\r\n          && request.resource.data.status == 'pending'\r\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\r\n            'status',\r\n            'proofUrl',\r\n            'proofMissingReason',\r\n            'proofRequired',\r\n            'cashierForwardedAt',\r\n            'cashierForwardedBy',\r\n            'cashierForwardedByName'\r\n          ])\r\n        );\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ── Staff profiles ─────────────────────────────────\r\n    // Staff can read their own profile only.\r\n    // Admin/superadmin can read and write all.\r\n    match /rehab_staff/{staffId} {\r\n      allow read: if isRehabAdminOrAbove()\r\n        || isRehabRole('cashier')\r\n        || (isRehabRole('staff') && rehabStaffId() == staffId)\r\n        || isHqSuperOrManager();\r\n      allow create, update: if isRehabAdminOrAbove() || isHqSuperOrManager();\r\n      allow delete: if isRehabSuperAdmin() || isHqSuperOrManager();\r\n    }\r\n\r\n    // ── Attendance ─────────────────────────────────────\r\n    // Staff can create their own attendance (self check-in).\r\n    // Admin can update (override). Nobody deletes.\r\n    match /rehab_attendance/{docId} {\r\n      allow read: if isRehabAdminOrAbove()\r\n        || isRehabRole('cashier')\r\n        || isRehabRole('staff')\r\n        || isHqSuperOrManager();\r\n      allow create: if isRehabRole('staff') || isRehabAdminOrAbove();\r\n      allow update: if isRehabRole('staff') || isRehabAdminOrAbove();\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ── Departmental Staff Operational Rules (Rehab, SPIMS, etc.) ─────────────────\r\n\r\n    // Patterns: {dept}_dress_code, {dept}_duty_log, {dept}_staff_dress_config, {dept}_staff_duty_config\r\n    \r\n    // REHAB\r\n    match /rehab_dress_code/{docId} {\r\n      allow read: if isHqSuperOrManager() || (isRehabAuth() && resource.data.staffId == request.auth.uid);\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n    match /rehab_duty_log/{docId} {\r\n      allow read: if isHqSuperOrManager() || (isRehabAuth() && resource.data.staffId == request.auth.uid);\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n    match /rehab_staff_dress_config/{docId} {\r\n      allow read: if isAuth(); // Any authenticated user can read config\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n    match /rehab_staff_duty_config/{docId} {\r\n      allow read: if isAuth();\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n\r\n    // ── Patient videos ─────────────────────────────────\r\n    // Family can read only their patient's videos.\r\n    // Admin/superadmin can read and write all.\r\n    match /rehab_videos/{docId} {\r\n      allow read: if isRehabAdminOrAbove()\r\n        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId);\r\n      allow create, update: if isRehabAdminOrAbove();\r\n      allow delete: if isRehabSuperAdmin();\r\n    }\r\n\r\n    // ── Patient visits ─────────────────────────────────\r\n    // Family can read only their patient's visits.\r\n    // Admin/superadmin can read and write all.\r\n    match /rehab_visits/{docId} {\r\n      allow read: if isRehabAdminOrAbove()\r\n        || (isRehabRole('family') && rehabPatientId() == resource.data.patientId);\r\n      allow create, update: if isRehabAdminOrAbove();\r\n      allow delete: if isRehabSuperAdmin();\r\n    }\r\n\r\n    // ── Audit log ──────────────────────────────────────\r\n    // Only superadmin can read. \r\n    // Server actions write via Admin SDK (bypasses rules).\r\n    // Client writes allowed for fire-and-forget audit entries\r\n    // from authenticated rehab users only.\r\n    match /rehab_audit/{docId} {\r\n      allow read: if isRehabSuperAdmin() || isHqSuperOrManager();\r\n      allow create: if isRehabAuth();\r\n      allow update, delete: if false;\r\n    }\r\n\r\n    // ── Deletion logs (Audit trail for sensitive financial deletions) ──\r\n    match /rehab_deletion_logs/{docId} {\r\n      allow read: if isRehabSuperAdmin();\r\n      allow create: if isRehabSuperAdmin();\r\n      allow update, delete: if false;\r\n    }\r\n\r\n    // ── Staff contributions ────────────────────────────\r\n    match /rehab_contributions/{docId} {\r\n      allow read: if isRehabRole('admin')\r\n        || isHqSuperOrManager()\r\n        || isOwnStaffRecord(resource.data.staffId);\r\n      allow create: if isRehabRole('staff') || isRehabRole('admin');\r\n      allow update: if isRehabRole('admin') || isHqSuperOrManager()\r\n        || (isOwnStaffRecord(resource.data.staffId)\r\n            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content']));\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ── Staff fines ────────────────────────────────────\r\n    // Admin/superadmin read and write. Staff reads own fines.\r\n    match /rehab_fines/{docId} {\r\n      allow read: if isRehabAdminOrAbove()\r\n        || (isRehabRole('staff') \r\n            && resource.data.staffId == request.auth.uid);\r\n      allow create, update: if isRehabAdminOrAbove();\r\n      allow delete: if isRehabSuperAdmin();\r\n    }\r\n\r\n    // ── Staff leaves ───────────────────────────────────\r\n    // Admin/superadmin read and write. Staff reads own leaves.\r\n    match /rehab_leaves/{docId} {\r\n      allow read: if isRehabAdminOrAbove()\r\n        || (isRehabRole('staff') \r\n            && resource.data.staffId == request.auth.uid);\r\n      allow create, update: if isRehabAdminOrAbove();\r\n      allow delete: if isRehabSuperAdmin();\r\n    }\r\n\r\n    // ── Duty Logs ─────────────────────────────────────────────────────────────\r\n    match /rehab_duty_logs/{docId} {\r\n      allow read: if isRehabRole('admin')\r\n        || isHqSuperOrManager()\r\n        || isOwnStaffRecord(resource.data.staffId);\r\n      allow create, update: if isRehabRole('admin') || isHqSuperOrManager();\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ── Dress Logs ────────────────────────────────────────────────────────────\r\n    match /rehab_dress_logs/{docId} {\r\n      allow read: if isRehabRole('admin')\r\n        || isHqSuperOrManager()\r\n        || isOwnStaffRecord(resource.data.staffId);\r\n      allow create, update: if isRehabRole('admin') || isHqSuperOrManager();\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ── Growth Points ─────────────────────────────────────────────────────────\r\n    match /rehab_growth_points/{docId} {\r\n      allow read: if isRehabRole('admin')\r\n        || isHqSuperOrManager()\r\n        || isOwnStaffRecord(resource.data.staffId);\r\n      allow create, update: if isRehabRole('admin') || isHqSuperOrManager();\r\n      allow delete: if false;\r\n    }\r\n\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  SPIMS COLLEGE PORTAL HELPERS\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    function isSpimsAuth() {\r\n      return request.auth != null\r\n        && exists(/databases/$(database)/documents/spims_users/$(request.auth.uid));\r\n    }\r\n    function spimsRole() {\r\n      return get(/databases/$(database)/documents/spims_users/$(request.auth.uid)).data.role;\r\n    }\r\n    function isSpimsRole(role) {\r\n      return isSpimsAuth() && spimsRole() == role;\r\n    }\r\n    function isSpimsAdminOrAbove() {\r\n      return isSpimsAuth()\r\n        && (spimsRole() == 'admin' || spimsRole() == 'superadmin');\r\n    }\r\n    function isSpimsSuperAdmin() {\r\n      return isSpimsRole('superadmin');\r\n    }\r\n    function spimsStudentId() {\r\n      return get(/databases/$(database)/documents/spims_users/$(request.auth.uid)).data.studentId;\r\n    }\r\n    function spimsStaffId() {\r\n      return get(/databases/$(database)/documents/spims_users/$(request.auth.uid)).data.staffId;\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  SPIMS COLLEGE PORTAL COLLECTIONS\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    match /spims_meta/{doc} {\r\n      allow read: if true;\r\n      allow write: if false;\r\n    }\r\n\r\n    match /spims_users/{uid} {\r\n      allow read: if (request.auth != null\r\n        && (request.auth.uid == uid || isSpimsAdminOrAbove()))\r\n        || isDiscoveryQuery()\r\n        || isHqSuperOrManager();\r\n      allow create: if isSpimsSuperAdmin() || isHqSuperOrManager();\r\n      allow delete: if isSpimsSuperAdmin() || isHqSuperOrManager();\r\n      allow update: if (request.auth != null\r\n        && request.auth.uid == uid\r\n        && request.resource.data.diff(resource.data)\r\n            .affectedKeys()\r\n            .hasOnly(['photoUrl', 'displayName', 'phone']))\r\n        || isHqSuperOrManager();\r\n    }\r\n\r\n    match /spims_students/{studentId} {\r\n      allow read: if isSpimsAdminOrAbove()\r\n        || isSpimsRole('cashier')\r\n        || (isSpimsRole('student') && spimsStudentId() == studentId);\r\n      allow create, update: if isSpimsAdminOrAbove();\r\n      allow delete: if isSpimsSuperAdmin();\r\n    }\r\n\r\n    match /spims_fees/{docId} {\r\n      allow read: if isSpimsAdminOrAbove()\r\n        || (isSpimsRole('cashier'))\r\n        || (isSpimsRole('student') && spimsStudentId() == resource.data.studentId)\r\n        || isHqSuperAdmin();\r\n      allow create: if isSpimsAdminOrAbove() || isSpimsRole('cashier');\r\n      allow update: if isSpimsAdminOrAbove() || isSpimsRole('cashier') || isSpimsSuperAdmin() || isHqSuperAdmin();\r\n      allow delete: if isSpimsSuperAdmin();\r\n    }\r\n\r\n    match /spims_student_documents/{docId} {\r\n      allow read: if isSpimsAdminOrAbove()\r\n        || (isSpimsRole('student') && spimsStudentId() == resource.data.studentId);\r\n      allow create, update, delete: if isSpimsAdminOrAbove();\r\n    }\r\n\r\n    // Student specific records (similar to patient records)\r\n    match /spims_board_fees/{docId} {\r\n      allow read: if isSpimsAdminOrAbove()\r\n        || (isSpimsRole('cashier'))\r\n        || (isSpimsRole('student') && spimsStudentId() == resource.data.studentId);\r\n      allow write: if isSpimsRole('cashier') || isSpimsSuperAdmin();\r\n    }\r\n\r\n    match /spims_exams/{docId} {\r\n      allow read: if isSpimsAdminOrAbove()\r\n        || (isSpimsRole('student') && spimsStudentId() == resource.data.studentId);\r\n      allow create, update: if isSpimsAdminOrAbove();\r\n      allow delete: if isSpimsSuperAdmin();\r\n    }\r\n\r\n    match /spims_transactions/{docId} {\r\n      allow read: if isSpimsAdminOrAbove() || isSpimsRole('cashier') || isHqSuperAdmin();\r\n      allow create: if isSpimsRole('cashier') || isSpimsSuperAdmin();\r\n      allow update: if isSpimsSuperAdmin() || isHqSuperAdmin();\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /spims_staff/{staffId} {\r\n      allow read: if isSpimsAdminOrAbove()\r\n        || isSpimsRole('cashier')\r\n        || (isSpimsRole('staff') && spimsStaffId() == staffId)\r\n        || isHqSuperOrManager();\r\n      allow create, update: if isSpimsAdminOrAbove() || isHqSuperOrManager();\r\n      allow delete: if isSpimsSuperAdmin() || isHqSuperOrManager();\r\n    }\r\n\r\n    match /spims_attendance/{docId} {\r\n      allow read: if isSpimsAdminOrAbove()\r\n        || isSpimsRole('cashier')\r\n        || isSpimsRole('staff')\r\n        || isHqSuperOrManager();\r\n      allow create, update: if isSpimsRole('staff') || isSpimsAdminOrAbove() || isHqSuperOrManager();\r\n      allow delete: if false;\r\n    }\r\n\r\n    // SPIMS\r\n    match /spims_dress_code/{docId} {\r\n      allow read: if isHqSuperOrManager() || (isSpimsAuth() && resource.data.staffId == request.auth.uid);\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n    match /spims_duty_log/{docId} {\r\n      allow read: if isHqSuperOrManager() || (isSpimsAuth() && resource.data.staffId == request.auth.uid);\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n    match /spims_staff_dress_config/{docId} {\r\n      allow read: if isAuth();\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n    match /spims_staff_duty_config/{docId} {\r\n      allow read: if isAuth();\r\n      allow write: if isHqSuperOrManager();\r\n    }\r\n\r\n    // SPIMS operational logs (named with _logs suffix)\r\n    match /spims_dress_logs/{logId} {\r\n      allow read: if isSpimsAdminOrAbove() || isHqSuperOrManager();\r\n      allow create, update: if isSpimsAdminOrAbove() || isHqSuperOrManager();\r\n    }\r\n    match /spims_duty_logs/{logId} {\r\n      allow read: if isSpimsAdminOrAbove() || isHqSuperOrManager();\r\n      allow create, update: if isSpimsAdminOrAbove() || isHqSuperOrManager();\r\n    }\r\n\r\n    // spims_tests — admin announcements for tests (course/session or single student)\r\n    function spimsStudentDoc() {\r\n      return get(/databases/$(database)/documents/spims_students/$(spimsStudentId())).data;\r\n    }\r\n    match /spims_tests/{docId} {\r\n      allow read: if isSpimsAdminOrAbove()\r\n        || (\r\n          isSpimsRole('student')\r\n          && (\r\n            resource.data.scope == 'all'\r\n            || (resource.data.scope == 'student' && resource.data.studentId == spimsStudentId())\r\n            || (\r\n              resource.data.scope == 'course_session'\r\n              && resource.data.course == spimsStudentDoc().course\r\n              && resource.data.session == spimsStudentDoc().session\r\n            )\r\n          )\r\n        );\r\n      allow create, update, delete: if isSpimsAdminOrAbove();\r\n    }\r\n\r\n    // spims_student_attendance — attendance marked by admin for students\r\n    match /spims_student_attendance/{docId} {\r\n      allow read: if isSpimsAdminOrAbove()\r\n        || (isSpimsRole('student') && resource.data.studentId == spimsStudentId());\r\n      allow create, update: if isSpimsAdminOrAbove();\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /spims_audit/{docId} {\r\n      allow read: if isSpimsSuperAdmin() || isHqSuperOrManager();\r\n      allow create: if isSpimsAuth();\r\n      allow update, delete: if false;\r\n    }\r\n\r\n    match /spims_salary_records/{docId} {\r\n      allow read: if isSpimsAdminOrAbove() || isSpimsRole('cashier');\r\n      allow create: if isSpimsSuperAdmin();\r\n      allow update: if isSpimsSuperAdmin();\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════ \r\n    //  HQ PORTAL HELPERS \r\n    //  Global system: superadmin, manager, cashier \r\n    //  Uses hq_users collection (doc ID = Firebase Auth uid) \r\n    // ═══════════════════════════════════════════════════════════ \r\n\r\n    function isHqAuth() { \r\n      return request.auth != null \r\n        && exists(/databases/$(database)/documents/hq_users/$(request.auth.uid)); \r\n    } \r\n    function hqRole() { \r\n      return get(/databases/$(database)/documents/hq_users/$(request.auth.uid)).data.role; \r\n    } \r\n    function hqCustomId() {\r\n      return get(/databases/$(database)/documents/hq_users/$(request.auth.uid)).data.customId;\r\n    }\r\n    function isHqRole(role) { \r\n      return isHqAuth() && hqRole() == role; \r\n    } \r\n    function isHqSuperAdmin() { \r\n      return isHqRole('superadmin'); \r\n    } \r\n    function isHqCashier() { \r\n      return isHqRole('cashier'); \r\n    } \r\n    function isHqSuperOrManager() { \r\n      return isHqAuth() && (hqRole() == 'superadmin' || hqRole() == 'manager'); \r\n    } \r\n    function isHqTier1() { \r\n      return isHqAuth() && hqRole() in ['superadmin', 'manager', 'cashier']; \r\n    } \r\n\r\n    // ═══════════════════════════════════════════════════════════ \r\n    //  HQ PORTAL COLLECTIONS \r\n    // ═══════════════════════════════════════════════════════════ \r\n\r\n    // hq_meta — one-time setup flag \r\n    // Public read so setup page can check initialization status. \r\n    // Write: Firebase Admin SDK only (server action). \r\n    match /hq_meta/{docId} { \r\n      allow read: if true; \r\n      allow write: if false; \r\n    } \r\n\r\n    // hq_users — superadmin / manager / cashier profiles\r\n    // Read: own doc OR any HQ tier1 user.\r\n    // Create/Delete: server-side (Admin SDK) only.\r\n    // Update:\r\n    //  - superadmin/manager can update users (e.g. isActive)\r\n    //  - owner can update limited profile fields only\r\n    match /hq_users/{docId} {\r\n      allow read: if (isHqAuth() && (request.auth.uid == docId || isHqTier1()))\r\n        || isDiscoveryQuery();\r\n      allow create, delete: if false;\r\n      allow update: if isHqSuperOrManager()\r\n        || (\r\n          isHqAuth()\r\n          && request.auth.uid == docId\r\n          && request.resource.data.diff(resource.data)\r\n              .affectedKeys()\r\n              .hasOnly(['photoUrl', 'name', 'phone'])\r\n        );\r\n\r\n      match /fcmTokens/{tokenId} {\r\n        allow read, write: if isHqAuth() && request.auth.uid == docId;\r\n      }\r\n    }\r\n\r\n    // hq_targets — monthly targets assigned to admin/staff \r\n    match /hq_targets/{docId} { \r\n      allow read: if isHqSuperOrManager() \r\n        || (request.auth != null && resource.data.staffId == request.auth.uid); \r\n      allow create: if isHqSuperOrManager(); \r\n      allow update: if isHqSuperOrManager(); \r\n      allow delete: if isHqSuperAdmin(); \r\n    } \r\n\r\n    // hq_salary_records — staff salary payment records \r\n    match /hq_salary_records/{docId} { \r\n      allow read: if isHqTier1() \r\n        || (request.auth != null && resource.data.staffId == request.auth.uid); \r\n      allow create: if isHqTier1(); \r\n      allow update: if isHqTier1(); \r\n      allow delete: if isHqSuperAdmin(); \r\n    } \r\n\r\n    // hq_cashier_categories — reusable custom income/expense fields\r\n    // Cashier/manager/superadmin can read and create.\r\n    // Manager/superadmin can edit/delete for governance.\r\n    match /hq_cashier_categories/{docId} {\r\n      allow read: if isHqTier1();\r\n      allow create: if isHqTier1();\r\n      allow update, delete: if isHqSuperOrManager();\r\n    }\r\n\r\n    // hq_fines — late/discipline fines auto-created on attendance \r\n    match /hq_fines/{docId} { \r\n      allow read: if isHqSuperOrManager() \r\n        || (request.auth != null && resource.data.staffId == request.auth.uid); \r\n      allow create: if isHqSuperOrManager(); \r\n      allow update: if isHqSuperOrManager(); \r\n      allow delete: if isHqSuperAdmin(); \r\n    } \r\n\r\n    // hq_audit — cross-system audit log \r\n    match /hq_audit/{docId} { \r\n      allow read: if isHqSuperOrManager(); \r\n      allow create: if isHqAuth(); \r\n    } \r\n\r\n    // hq_settings — HQ superadmin settings (toggles/thresholds)\r\n    match /hq_settings/{docId} {\r\n      allow read: if isHqSuperAdmin();\r\n      allow create, update: if isHqSuperAdmin();\r\n      allow delete: if false;\r\n    }\r\n\r\n    // hq_notifications — in-app notifications for HQ users\r\n    match /hq_notifications/{docId} {\r\n      allow read: if isHqAuth()\r\n        && resource.data.recipientId == get(/databases/$(database)/documents/hq_users/$(request.auth.uid)).data.customId;\r\n      allow create: if isHqAuth();\r\n      allow update: if isHqAuth()\r\n        && resource.data.recipientId == get(/databases/$(database)/documents/hq_users/$(request.auth.uid)).data.customId\r\n        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);\r\n      allow delete: if false;\r\n    }\r\n\r\n    // hq_ledger_entries — immutable canonical ledger\r\n    // Written by server action (Admin SDK) on every superadmin approval.\r\n    // HQ tier1 can read. Nobody deletes or updates from client.\r\n    match /hq_ledger_entries/{docId} {\r\n      allow read: if isHqTier1();\r\n      allow create: if isHqSuperAdmin();\r\n      allow update, delete: if false;\r\n    }\r\n\r\n    // hq_reconciliation — daily cashier close records\r\n    // Cashier creates. Superadmin/manager reads and verifies.\r\n    // Nobody edits or deletes.\r\n    match /hq_reconciliation/{docId} {\r\n      allow read: if isHqSuperOrManager()\r\n        || (isHqCashier() && resource.data.cashierId == hqCustomId());\r\n      allow create: if isHqCashier() || isHqSuperOrManager();\r\n      allow update: if isHqSuperOrManager();\r\n      allow delete: if false;\r\n    }\r\n\r\n    // hq_growth_points — points system for HQ staff\r\n    match /hq_growth_points/{docId} { \r\n      allow read: if isHqSuperOrManager() \r\n        || (request.auth != null && resource.data.staffId == request.auth.uid); \r\n      allow create, update: if isHqSuperOrManager(); \r\n      allow delete: if isHqSuperAdmin(); \r\n    } \r\n\r\n    // cashierTransactions — standardized global transaction log\r\n    match /cashierTransactions/{docId} {\r\n      allow read: if isHqTier1();\r\n      allow create: if isHqCashier() || isHqSuperOrManager();\r\n      allow update: if isHqSuperOrManager();\r\n      allow delete: if false;\r\n    }\r\n\r\n    // hq_fees — global fee records (direct HQ collections)\r\n    match /hq_fees/{docId} {\r\n      allow read: if isHqSuperOrManager() || isHqCashier();\r\n      allow create, update: if isHqCashier() || isHqSuperAdmin();\r\n      allow delete: if isHqSuperAdmin();\r\n    }\r\n\r\n    // hq_staff — global staff profiles across all departments \r\n    // Read: any HQ tier1 OR rehab/spims admin \r\n    // Write: superadmin or manager only \r\n    match /hq_staff/{staffId} { \r\n      allow read: if isHqSuperOrManager(); \r\n      allow create, update, delete: if isHqSuperOrManager(); \r\n    } \r\n\r\n    // hq_attendance — staff attendance records (marked by manager only) \r\n    match /hq_attendance/{docId} { \r\n      allow read, create, update, delete: if isHqSuperOrManager(); \r\n    } \r\n\r\n    // ── Future departments staff-management (manager/superadmin only) ────────\r\n    // Any new department that follows naming:\r\n    //   {dept}_staff, {dept}_attendance, {dept}_duty_logs\r\n    // is automatically manageable from HQ by manager/superadmin/cashier.\r\n    match /{collectionId}/{docId} {\r\n      allow read: if (isHqTier1()\r\n        && (\r\n          collectionId.matches('^[a-z0-9_-]+_staff$')\r\n          || collectionId.matches('^[a-z0-9_-]+_attendance$')\r\n          || collectionId.matches('^[a-z0-9_-]+_duty_logs$')\r\n          || collectionId.matches('^[a-z0-9_-]+_duty_log$')\r\n          || collectionId.matches('^[a-z0-9_-]+_dress_logs$')\r\n          || collectionId.matches('^[a-z0-9_-]+_dress_code$')\r\n          || collectionId.matches('^[a-z0-9_-]+_fines$')\r\n          || collectionId.matches('^[a-z0-9_-]+_growth_points$')\r\n          || collectionId.matches('^[a-z0-9_-]+_users$')\r\n          || collectionId.matches('^[a-z0-9_-]+_debtors$')\r\n          || collectionId.matches('^[a-z0-9_-]+_audit$')\r\n          || collectionId.matches('^[a-z0-9_-]+_contributions$')\r\n          || collectionId.matches('^[a-z0-9_-]+_salary_records$')\r\n          || collectionId.matches('^[a-z0-9_-]+_special_tasks$')\r\n          || collectionId.matches('^[a-z0-9_-]+_meta$')\r\n        )) || (isDiscoveryQuery() && collectionId.matches('^[a-z0-9_-]+_users$'));\r\n      allow create, update: if (isHqSuperOrManager() || (isHqCashier() && collectionId.matches('^[a-z0-9_-]+_salary_records$')))\r\n        && (\r\n          collectionId.matches('^[a-z0-9_-]+_staff$')\r\n          || collectionId.matches('^[a-z0-9_-]+_attendance$')\r\n          || collectionId.matches('^[a-z0-9_-]+_duty_logs$')\r\n          || collectionId.matches('^[a-z0-9_-]+_duty_log$')\r\n          || collectionId.matches('^[a-z0-9_-]+_dress_logs$')\r\n          || collectionId.matches('^[a-z0-9_-]+_dress_code$')\r\n          || collectionId.matches('^[a-z0-9_-]+_fines$')\r\n          || collectionId.matches('^[a-z0-9_-]+_growth_points$')\r\n          || collectionId.matches('^[a-z0-9_-]+_users$')\r\n          || collectionId.matches('^[a-z0-9_-]+_debtors$')\r\n          || collectionId.matches('^[a-z0-9_-]+_audit$')\r\n          || collectionId.matches('^[a-z0-9_-]+_contributions$')\r\n          || collectionId.matches('^[a-z0-9_-]+_salary_records$')\r\n          || collectionId.matches('^[a-z0-9_-]+_special_tasks$')\r\n          || collectionId.matches('^[a-z0-9_-]+_meta$')\r\n        );\r\n      allow delete: if isHqSuperOrManager()\r\n        && (\r\n          collectionId.matches('^[a-z0-9_-]+_staff$')\r\n          || collectionId.matches('^[a-z0-9_-]+_users$')\r\n          || collectionId.matches('^[a-z0-9_-]+_fines$')\r\n          || collectionId.matches('^[a-z0-9_-]+_special_tasks$')\r\n          || collectionId.matches('^[a-z0-9_-]+_meta$')\r\n        );\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  HOSPITAL PORTAL HELPERS\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    function isHospitalAuth() {\r\n      return request.auth != null\r\n        && exists(/databases/$(database)/documents/hospital_users/$(request.auth.uid));\r\n    }\r\n    function hospitalRole() {\r\n      return get(/databases/$(database)/documents/hospital_users/$(request.auth.uid)).data.role;\r\n    }\r\n    function isHospitalRole(role) {\r\n      return isHospitalAuth() && hospitalRole() == role;\r\n    }\r\n    function isHospitalAdminOrAbove() {\r\n      return isHospitalAuth()\r\n        && (hospitalRole() == 'admin' || hospitalRole() == 'superadmin');\r\n    }\r\n    function isHospitalSuperAdmin() {\r\n      return isHospitalRole('superadmin');\r\n    }\r\n    function hospitalPatientId() {\r\n      return get(/databases/$(database)/documents/hospital_users/$(request.auth.uid)).data.patientId;\r\n    }\r\n    function hospitalStaffId() {\r\n      return get(/databases/$(database)/documents/hospital_users/$(request.auth.uid)).data.staffId;\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  HOSPITAL PORTAL COLLECTIONS\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    match /hospital_meta/{doc} {\r\n      allow read: if true;\r\n      allow write: if false;\r\n    }\r\n\r\n    match /hospital_users/{uid} {\r\n      allow read: if (request.auth != null\r\n        && (request.auth.uid == uid || isHospitalAdminOrAbove()))\r\n        || isHqSuperOrManager();\r\n      allow create: if isHospitalSuperAdmin() || isHqSuperOrManager();\r\n      allow delete: if isHospitalSuperAdmin() || isHqSuperOrManager();\r\n      allow update: if (request.auth != null\r\n        && request.auth.uid == uid\r\n        && request.resource.data.diff(resource.data)\r\n            .affectedKeys()\r\n            .hasOnly(['photoUrl', 'displayName', 'phone']))\r\n        || isHqSuperOrManager();\r\n    }\r\n\r\n    match /hospital_patients/{patientId} {\r\n      allow read: if isHospitalAdminOrAbove()\r\n        || isHospitalRole('cashier')\r\n        || (isHospitalRole('patient') && hospitalPatientId() == patientId);\r\n      allow create, update: if isHospitalAdminOrAbove() || isHqSuperOrManager();\r\n      allow delete: if isHospitalSuperAdmin();\r\n    }\r\n\r\n    match /hospital_fees/{docId} {\r\n      allow read: if isHospitalAdminOrAbove()\r\n        || (isHospitalRole('cashier'))\r\n        || (isHospitalRole('patient') && hospitalPatientId() == resource.data.patientId);\r\n      allow write: if isHospitalRole('cashier') || isHospitalSuperAdmin();\r\n    }\r\n\r\n    match /hospital_transactions/{docId} {\r\n      allow read: if isHospitalAdminOrAbove() || isHospitalRole('cashier');\r\n      allow create: if isHospitalRole('cashier')\r\n        || isHospitalSuperAdmin()\r\n        || (isHospitalAdminOrAbove() && request.resource.data.status == 'pending_cashier');\r\n      allow update: if isHospitalSuperAdmin()\r\n        || (\r\n          isHospitalRole('cashier')\r\n          && resource.data.status == 'pending_cashier'\r\n          && request.resource.data.status == 'pending'\r\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\r\n            'status',\r\n            'proofUrl',\r\n            'proofMissingReason',\r\n            'proofRequired',\r\n            'cashierForwardedAt',\r\n            'cashierForwardedBy',\r\n            'cashierForwardedByName'\r\n          ])\r\n        );\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /hospital_staff/{staffId} {\r\n      allow read: if isHospitalAdminOrAbove()\r\n        || isHospitalRole('cashier')\r\n        || (isHospitalRole('staff') && hospitalStaffId() == staffId)\r\n        || isHqSuperOrManager();\r\n      allow create, update: if isHospitalAdminOrAbove() || isHqSuperOrManager();\r\n      allow delete: if isHospitalSuperAdmin() || isHqSuperOrManager();\r\n    }\r\n\r\n    match /hospital_attendance/{docId} {\r\n      allow read: if isHospitalAdminOrAbove()\r\n        || isHospitalRole('cashier')\r\n        || isHospitalRole('staff')\r\n        || isHqSuperOrManager();\r\n      allow create, update: if isHospitalRole('staff') || isHospitalAdminOrAbove() || isHqSuperOrManager();\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /hospital_dress_logs/{logId} {\r\n      allow read: if isHospitalAdminOrAbove() || isHqSuperOrManager();\r\n      allow create, update: if isHospitalAdminOrAbove() || isHqSuperOrManager();\r\n    }\r\n\r\n    match /hospital_duty_logs/{logId} {\r\n      allow read: if isHospitalAdminOrAbove() || isHqSuperOrManager();\r\n      allow create, update: if isHospitalAdminOrAbove() || isHqSuperOrManager();\r\n    }\r\n\r\n    match /hospital_audit/{docId} {\r\n      allow read: if isHospitalSuperAdmin() || isHqSuperOrManager();\r\n      allow create: if isHospitalAuth();\r\n      allow update, delete: if false;\r\n    }\r\n\r\n    match /hospital_salary_records/{docId} {\r\n      allow read: if isHospitalAdminOrAbove();\r\n      allow write: if isHospitalAdminOrAbove();\r\n      allow delete: if isHospitalSuperAdmin();\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  SUKOON PORTAL HELPERS\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    function isSukoonAuth() {\r\n      return request.auth != null\r\n        && exists(/databases/$(database)/documents/sukoon_users/$(request.auth.uid));\r\n    }\r\n    function sukoonRole() {\r\n      return get(/databases/$(database)/documents/sukoon_users/$(request.auth.uid)).data.role;\r\n    }\r\n    function isSukoonRole(role) {\r\n      return isSukoonAuth() && sukoonRole() == role;\r\n    }\r\n    function isSukoonAdminOrAbove() {\r\n      return isSukoonAuth()\r\n        && (sukoonRole() == 'admin' || sukoonRole() == 'superadmin');\r\n    }\r\n    function isSukoonSuperAdmin() {\r\n      return isSukoonRole('superadmin');\r\n    }\r\n    function sukoonClientId() {\r\n      return get(/databases/$(database)/documents/sukoon_users/$(request.auth.uid)).data.clientId;\r\n    }\r\n    function sukoonStaffId() {\r\n      return get(/databases/$(database)/documents/sukoon_users/$(request.auth.uid)).data.staffId;\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  SUKOON PORTAL COLLECTIONS\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    match /sukoon_meta/{doc} {\r\n      allow read: if true;\r\n      allow write: if false;\r\n    }\r\n\r\n    match /sukoon_users/{uid} {\r\n      allow read: if (request.auth != null\r\n        && (request.auth.uid == uid || isSukoonAdminOrAbove()))\r\n        || isDiscoveryQuery()\r\n        || isHqSuperOrManager();\r\n      allow create: if isSukoonSuperAdmin() || isHqSuperOrManager();\r\n      allow delete: if isSukoonSuperAdmin() || isHqSuperOrManager();\r\n      allow update: if (request.auth != null\r\n        && request.auth.uid == uid\r\n        && request.resource.data.diff(resource.data)\r\n            .affectedKeys()\r\n            .hasOnly(['photoUrl', 'displayName', 'phone']))\r\n        || isHqSuperOrManager();\r\n    }\r\n\r\n    match /sukoon_clients/{clientId} {\r\n      allow read: if isSukoonAdminOrAbove()\r\n        || isSukoonRole('cashier')\r\n        || (isSukoonRole('client') && sukoonClientId() == clientId);\r\n      allow create, update: if isSukoonAdminOrAbove() || isHqSuperOrManager();\r\n      allow delete: if isSukoonSuperAdmin();\r\n    }\r\n\r\n    match /sukoon_fees/{docId} {\r\n      allow read: if isSukoonAdminOrAbove()\r\n        || (isSukoonRole('cashier'))\r\n        || (isSukoonRole('client') && sukoonClientId() == resource.data.clientId);\r\n      allow write: if isSukoonRole('cashier') || isSukoonSuperAdmin();\r\n    }\r\n\r\n    match /sukoon_transactions/{docId} {\r\n      allow read: if isSukoonAdminOrAbove() || isSukoonRole('cashier');\r\n      allow create: if isSukoonRole('cashier')\r\n        || isSukoonSuperAdmin()\r\n        || (isSukoonAdminOrAbove() && request.resource.data.status == 'pending_cashier');\r\n      allow update: if isSukoonSuperAdmin()\r\n        || (\r\n          isSukoonRole('cashier')\r\n          && resource.data.status == 'pending_cashier'\r\n          && request.resource.data.status == 'pending'\r\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\r\n            'status',\r\n            'proofUrl',\r\n            'proofMissingReason',\r\n            'proofRequired',\r\n            'cashierForwardedAt',\r\n            'cashierForwardedBy',\r\n            'cashierForwardedByName'\r\n          ])\r\n        );\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /sukoon_staff/{staffId} {\r\n      allow read: if isSukoonAdminOrAbove()\r\n        || isSukoonRole('cashier')\r\n        || (isSukoonRole('staff') && sukoonStaffId() == staffId)\r\n        || isHqSuperOrManager();\r\n      allow create, update: if isSukoonAdminOrAbove() || isHqSuperOrManager();\r\n      allow delete: if isSukoonSuperAdmin() || isHqSuperOrManager();\r\n    }\r\n\r\n    match /sukoon_attendance/{docId} {\r\n      allow read: if isSukoonAdminOrAbove()\r\n        || isSukoonRole('cashier')\r\n        || isSukoonRole('staff')\r\n        || isHqSuperOrManager();\r\n      allow create, update: if isSukoonRole('staff') || isSukoonAdminOrAbove() || isHqSuperOrManager();\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /sukoon_dress_logs/{logId} {\r\n      allow read: if isSukoonAdminOrAbove() || isHqSuperOrManager();\r\n      allow create, update: if isSukoonAdminOrAbove() || isHqSuperOrManager();\r\n    }\r\n\r\n    match /sukoon_duty_logs/{logId} {\r\n      allow read: if isSukoonAdminOrAbove() || isHqSuperOrManager();\r\n      allow create, update: if isSukoonAdminOrAbove() || isHqSuperOrManager();\r\n    }\r\n\r\n    match /sukoon_audit/{docId} {\r\n      allow read: if isSukoonSuperAdmin() || isHqSuperOrManager();\r\n      allow create: if isSukoonAuth();\r\n      allow update, delete: if false;\r\n    }\r\n\r\n    match /sukoon_salary_records/{docId} {\r\n      allow read: if isSukoonAdminOrAbove();\r\n      allow write: if isSukoonAdminOrAbove();\r\n      allow delete: if isSukoonSuperAdmin();\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  WELFARE PORTAL HELPERS\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    function isWelfareAuth() {\r\n      return request.auth != null\r\n        && exists(/databases/$(database)/documents/welfare_users/$(request.auth.uid));\r\n    }\r\n    function welfareRole() {\r\n      return get(/databases/$(database)/documents/welfare_users/$(request.auth.uid)).data.role;\r\n    }\r\n    function isWelfareRole(role) {\r\n      return isWelfareAuth() && welfareRole() == role;\r\n    }\r\n    function isWelfareAdminOrAbove() {\r\n      return isWelfareAuth()\r\n        && (welfareRole() == 'admin' || welfareRole() == 'superadmin');\r\n    }\r\n    function isWelfareSuperAdmin() {\r\n      return isWelfareRole('superadmin');\r\n    }\r\n    function welfareChildId() {\r\n      return get(/databases/$(database)/documents/welfare_users/$(request.auth.uid)).data.childId;\r\n    }\r\n    function welfareStaffId() {\r\n      return get(/databases/$(database)/documents/welfare_users/$(request.auth.uid)).data.staffId;\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  WELFARE PORTAL COLLECTIONS\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    match /welfare_meta/{doc} {\r\n      allow read: if true;\r\n      allow write: if false;\r\n    }\r\n\r\n    match /welfare_users/{uid} {\r\n      allow read: if (request.auth != null\r\n        && (request.auth.uid == uid || isWelfareAdminOrAbove()))\r\n        || isHqSuperOrManager();\r\n      allow create: if isWelfareSuperAdmin() || isHqSuperOrManager();\r\n      allow delete: if isWelfareSuperAdmin() || isHqSuperOrManager();\r\n      allow update: if (request.auth != null\r\n        && request.auth.uid == uid\r\n        && request.resource.data.diff(resource.data)\r\n            .affectedKeys()\r\n            .hasOnly(['photoUrl', 'displayName', 'phone']))\r\n        || isHqSuperOrManager();\r\n    }\r\n\r\n    match /welfare_children/{childId} {\r\n      allow read: if isWelfareAdminOrAbove()\r\n        || isWelfareRole('cashier')\r\n        || (isWelfareRole('child') && welfareChildId() == childId);\r\n      allow create, update: if isWelfareAdminOrAbove();\r\n      allow delete: if isWelfareSuperAdmin();\r\n    }\r\n\r\n    match /welfare_donors/{donorId} {\r\n      allow read: if isWelfareAdminOrAbove()\r\n        || isWelfareRole('cashier');\r\n      allow create, update: if isWelfareAdminOrAbove();\r\n      allow delete: if isWelfareSuperAdmin();\r\n    }\r\n\r\n    match /welfare_fees/{docId} {\r\n      allow read: if isWelfareAdminOrAbove()\r\n        || (isWelfareRole('cashier'))\r\n        || (isWelfareRole('child') && welfareChildId() == resource.data.childId);\r\n      allow write: if isWelfareRole('cashier') || isWelfareSuperAdmin();\r\n    }\r\n\r\n    match /welfare_transactions/{docId} {\r\n      allow read: if isWelfareAdminOrAbove() || isWelfareRole('cashier');\r\n      allow create: if isWelfareRole('cashier')\r\n        || isWelfareSuperAdmin()\r\n        || (isWelfareAdminOrAbove() && request.resource.data.status == 'pending_cashier');\r\n      allow update: if isWelfareSuperAdmin()\r\n        || (\r\n          isWelfareRole('cashier')\r\n          && resource.data.status == 'pending_cashier'\r\n          && request.resource.data.status == 'pending'\r\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\r\n            'status',\r\n            'proofUrl',\r\n            'proofMissingReason',\r\n            'proofRequired',\r\n            'cashierForwardedAt',\r\n            'cashierForwardedBy',\r\n            'cashierForwardedByName'\r\n          ])\r\n        );\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /welfare_staff/{staffId} {\r\n      allow read: if isWelfareAdminOrAbove()\r\n        || isWelfareRole('cashier')\r\n        || (isWelfareRole('staff') && welfareStaffId() == staffId)\r\n        || isHqSuperOrManager();\r\n      allow create, update: if isWelfareAdminOrAbove() || isHqSuperOrManager();\r\n      allow delete: if isWelfareSuperAdmin() || isHqSuperOrManager();\r\n    }\r\n\r\n    match /welfare_attendance/{docId} {\r\n      allow read: if isWelfareAdminOrAbove()\r\n        || isWelfareRole('cashier')\r\n        || isWelfareRole('staff')\r\n        || isHqSuperOrManager();\r\n      allow create, update: if isWelfareRole('staff') || isWelfareAdminOrAbove() || isHqSuperOrManager();\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /welfare_dress_logs/{logId} {\r\n      allow read: if isWelfareAdminOrAbove() || isHqSuperOrManager();\r\n      allow create, update: if isWelfareAdminOrAbove() || isHqSuperOrManager();\r\n    }\r\n\r\n    match /welfare_duty_logs/{logId} {\r\n      allow read: if isWelfareAdminOrAbove() || isHqSuperOrManager();\r\n      allow create, update: if isWelfareAdminOrAbove() || isHqSuperOrManager();\r\n    }\r\n\r\n    match /welfare_audit/{docId} {\r\n      allow read: if isWelfareSuperAdmin() || isHqSuperOrManager();\r\n      allow create: if isWelfareAuth();\r\n      allow update, delete: if false;\r\n    }\r\n\r\n    match /welfare_salary_records/{docId} {\r\n      allow read: if isWelfareAdminOrAbove();\r\n      allow write: if isWelfareAdminOrAbove();\r\n      allow delete: if isWelfareSuperAdmin();\r\n    }\r\n\r\n    match /welfare_canteen/{docId} {\r\n      allow read: if isWelfareAdminOrAbove()\r\n        || isWelfareRole('cashier')\r\n        || (isWelfareRole('child') && welfareChildId() == resource.data.childId);\r\n      allow create, update: if isWelfareRole('cashier') || isWelfareAdminOrAbove();\r\n      allow delete: if isWelfareSuperAdmin();\r\n    }\r\n\r\n    match /welfare_videos/{docId} {\r\n      allow read: if isWelfareAdminOrAbove()\r\n        || (isWelfareRole('child') && welfareChildId() == resource.data.patientId);\r\n      allow create: if isWelfareAdminOrAbove();\r\n      allow delete: if isWelfareAdminOrAbove();\r\n    }\r\n\r\n    match /welfare_visits/{docId} {\r\n      allow read: if isWelfareAdminOrAbove()\r\n        || (isWelfareRole('child') && welfareChildId() == resource.data.patientId);\r\n      allow create, update: if isWelfareAdminOrAbove();\r\n      allow delete: if isWelfareSuperAdmin();\r\n    }\r\n\r\n    match /welfare_fines/{docId} {\r\n      allow read: if isWelfareAdminOrAbove()\r\n        || (isWelfareRole('staff') && welfareStaffId() == resource.data.staffId);\r\n      allow create, update: if isWelfareAdminOrAbove();\r\n      allow delete: if isWelfareSuperAdmin();\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  JOB CENTER PORTAL HELPERS\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    function isJobCenterAuth() {\r\n      return request.auth != null\r\n        && (exists(/databases/$(database)/documents/job_center_users/$(request.auth.uid))\r\n            || exists(/databases/$(database)/documents/jobcenter_users/$(request.auth.uid)));\r\n    }\r\n    function jobCenterRole() {\r\n      return exists(/databases/$(database)/documents/job_center_users/$(request.auth.uid))\r\n        ? get(/databases/$(database)/documents/job_center_users/$(request.auth.uid)).data.role\r\n        : get(/databases/$(database)/documents/jobcenter_users/$(request.auth.uid)).data.role;\r\n    }\r\n    function isJobCenterRole(role) {\r\n      return isJobCenterAuth() && jobCenterRole() == role;\r\n    }\r\n    function isJobCenterAdminOrAbove() {\r\n      return isJobCenterAuth()\r\n        && (jobCenterRole() == 'admin' || jobCenterRole() == 'superadmin');\r\n    }\r\n    function isJobCenterSuperAdmin() {\r\n      return isJobCenterRole('superadmin');\r\n    }\r\n    function jobCenterSeekerId() {\r\n      return exists(/databases/$(database)/documents/job_center_users/$(request.auth.uid))\r\n        ? get(/databases/$(database)/documents/job_center_users/$(request.auth.uid)).data.seekerId\r\n        : get(/databases/$(database)/documents/jobcenter_users/$(request.auth.uid)).data.seekerId;\r\n    }\r\n    function jobCenterStaffId() {\r\n      return exists(/databases/$(database)/documents/job_center_users/$(request.auth.uid))\r\n        ? get(/databases/$(database)/documents/job_center_users/$(request.auth.uid)).data.staffId\r\n        : get(/databases/$(database)/documents/jobcenter_users/$(request.auth.uid)).data.staffId;\r\n    }\r\n\r\n    // ═══════════════════════════════════════════════════════════\r\n    //  JOB CENTER PORTAL COLLECTIONS\r\n    // ═══════════════════════════════════════════════════════════\r\n\r\n    match /job_center_meta/{doc} {\r\n      allow read: if true;\r\n      allow write: if false;\r\n    }\r\n    match /jobcenter_meta/{doc} {\r\n      allow read: if true;\r\n      allow write: if false;\r\n    }\r\n\r\n    match /job_center_users/{uid} {\r\n      allow read: if (request.auth != null\r\n        && (request.auth.uid == uid || isJobCenterAdminOrAbove()))\r\n        || isHqSuperOrManager();\r\n      allow create: if isJobCenterSuperAdmin() || isHqSuperOrManager();\r\n      allow delete: if isJobCenterSuperAdmin() || isHqSuperOrManager();\r\n      allow update: if (request.auth != null\r\n        && request.auth.uid == uid\r\n        && request.resource.data.diff(resource.data)\r\n            .affectedKeys()\r\n            .hasOnly(['photoUrl', 'displayName', 'phone']))\r\n        || isHqSuperOrManager();\r\n    }\r\n\r\n    match /jobcenter_users/{uid} {\r\n      allow read: if (request.auth != null\r\n        && (request.auth.uid == uid || isJobCenterAdminOrAbove()))\r\n        || isHqSuperOrManager();\r\n      allow create: if isJobCenterSuperAdmin() || isHqSuperOrManager();\r\n      allow delete: if isJobCenterSuperAdmin() || isHqSuperOrManager();\r\n      allow update: if (request.auth != null\r\n        && request.auth.uid == uid\r\n        && request.resource.data.diff(resource.data)\r\n            .affectedKeys()\r\n            .hasOnly(['photoUrl', 'displayName', 'phone']))\r\n        || isHqSuperOrManager();\r\n    }\r\n\r\n    match /job_center_seekers/{seekerId} {\r\n      allow read: if resource.data.isActive == true \r\n        || isJobCenterAdminOrAbove()\r\n        || isJobCenterRole('cashier')\r\n        || (isJobCenterRole('seeker') && jobCenterSeekerId() == seekerId);\r\n      allow create, update: if isJobCenterAdminOrAbove();\r\n      allow delete: if isJobCenterSuperAdmin();\r\n    }\r\n\r\n    match /jobcenter_seekers/{seekerId} {\r\n      allow read: if resource.data.isActive == true \r\n        || isJobCenterAdminOrAbove()\r\n        || isJobCenterRole('cashier')\r\n        || (isJobCenterRole('seeker') && jobCenterSeekerId() == seekerId);\r\n      allow create, update: if isJobCenterAdminOrAbove();\r\n      allow delete: if isJobCenterSuperAdmin();\r\n    }\r\n\r\n    match /job_center_employers/{employerId} {\r\n      allow read: if resource.data.isActive == true \r\n        || isJobCenterAdminOrAbove()\r\n        || isHqTier1();\r\n      allow create, update: if isJobCenterAdminOrAbove();\r\n      allow delete: if isJobCenterSuperAdmin();\r\n    }\r\n\r\n    match /jobcenter_employers/{employerId} {\r\n      allow read: if resource.data.isActive == true \r\n        || isJobCenterAdminOrAbove()\r\n        || isHqTier1();\r\n      allow create, update: if isJobCenterAdminOrAbove();\r\n      allow delete: if isJobCenterSuperAdmin();\r\n    }\r\n\r\n    match /job_center_fees/{docId} {\r\n      allow read: if isJobCenterAdminOrAbove()\r\n        || (isJobCenterRole('cashier'))\r\n        || (isJobCenterRole('seeker') && jobCenterSeekerId() == resource.data.seekerId);\r\n      allow write: if isJobCenterRole('cashier') || isJobCenterSuperAdmin();\r\n    }\r\n\r\n    match /jobcenter_fees/{docId} {\r\n      allow read: if isJobCenterAdminOrAbove()\r\n        || (isJobCenterRole('cashier'))\r\n        || (isJobCenterRole('seeker') && jobCenterSeekerId(